@page
@model MiddlewareEngine.Pages.Projects.ManageResourcesModel
@{
    ViewData["Title"] = "Manage Project Resources";
}

<nav aria-label="breadcrumb" style="margin-bottom:1.5rem;">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/Dashboard"><i class="bi bi-house-door"></i> Home</a></li>
        <li class="breadcrumb-item"><a href="/Projects"><i class="bi bi-folder"></i> Projects</a></li>
        <li class="breadcrumb-item active" aria-current="page"><i class="bi bi-link-45deg"></i> Manage Resources</li>
    </ol>
</nav>

<div style="max-width:1400px;margin:0 auto;">
    <div class="card" style="margin-bottom:2rem;">
        <div class="card-body">
            <h2 style="margin-bottom:1rem;color:#1e293b;">
                <i class="bi bi-link-45deg"></i> Manage Resources for Project
            </h2>
            <div id="projectInfo" style="padding:1rem;background-color:#f8fafc;border-radius:0.5rem;margin-bottom:1.5rem;">
                <div style="font-size:1.1rem;font-weight:600;color:#1e293b;margin-bottom:0.5rem;">
                    <i class="bi bi-folder"></i> <span id="projectName">Loading...</span>
                </div>
                <div style="font-size:0.875rem;color:#64748b;" id="projectDescription"></div>
                <div style="font-size:0.875rem;color:#64748b;margin-top:0.5rem;" id="projectCustomer"></div>
            </div>

            <div class="row">
                <!-- Available Setups -->
                <div class="col-md-5">
                    <div class="card">
                        <div class="card-header bg-light">
                            <h5 class="mb-0"><i class="bi bi-diagram-3"></i> Available Setups</h5>
                            <input type="text" id="setupSearch" class="form-control form-control-sm mt-2" placeholder="Search setups...">
                        </div>
                        <div class="card-body" style="max-height:500px;overflow-y:auto;">
                            <div id="availableSetups">Loading...</div>
                        </div>
                    </div>
                </div>

                <!-- Actions -->
                <div class="col-md-2 d-flex flex-column justify-content-center align-items-center">
                    <button class="btn btn-primary mb-3" onclick="assignSelected()" style="width:100%;">
                        <i class="bi bi-arrow-right"></i> Assign
                    </button>
                    <button class="btn btn-warning" onclick="unassignSelected()" style="width:100%;">
                        <i class="bi bi-arrow-left"></i> Remove
                    </button>
                </div>

                <!-- Assigned Setups -->
                <div class="col-md-5">
                    <div class="card">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0"><i class="bi bi-check-circle"></i> Assigned Setups (<span id="assignedCount">0</span>)</h5>
                        </div>
                        <div class="card-body" style="max-height:500px;overflow-y:auto;">
                            <div id="assignedSetups">Loading...</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-4">
                <button class="btn btn-success btn-lg" onclick="saveChanges()">
                    <i class="bi bi-save"></i> Save Changes
                </button>
                <a href="/Projects" class="btn btn-secondary btn-lg">
                    <i class="bi bi-x-circle"></i> Cancel
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .setup-item {
        padding: 0.75rem;
        margin-bottom: 0.5rem;
        border: 1px solid #e2e8f0;
        border-radius: 0.375rem;
        cursor: pointer;
        transition: all 0.2s;
    }
    .setup-item:hover {
        background-color: #f1f5f9;
        border-color: #cbd5e1;
    }
    .setup-item.selected {
        background-color: #dbeafe;
        border-color: #3b82f6;
    }
    .setup-item h6 {
        margin: 0 0 0.25rem 0;
        font-size: 0.95rem;
        font-weight: 600;
        color: #1e293b;
    }
    .setup-item .setup-type {
        font-size: 0.75rem;
        color: #64748b;
        margin-bottom: 0.25rem;
    }
    .setup-item .instrument-count {
        font-size: 0.7rem;
        color: #94a3b8;
    }
    .breadcrumb {
        background-color: #f8fafc;
        padding: 0.75rem 1rem;
        border-radius: 0.375rem;
    }
    .breadcrumb-item a {
        color: #3b82f6;
        text-decoration: none;
    }
    .breadcrumb-item a:hover {
        text-decoration: underline;
    }
    .breadcrumb-item.active {
        color: #64748b;
    }
</style>

<script>
    let projectId = null;
    let project = null;
    let allSetups = [];
    let availableSetups = [];
    let assignedSetupIds = [];
    let selectedAvailable = new Set();
    let selectedAssigned = new Set();

    window.onload = async function() {
        const params = new URLSearchParams(window.location.search);
        projectId = params.get('id');
        
        if (!projectId) {
            showToast('No project ID provided', 'error');
            setTimeout(function() { window.location.href = '/Projects'; }, 1000);
            return;
        }

        await loadData();
    };

    async function loadData() {
        try {
            // Load project
            const projectRes = await fetch('/api/projects/' + projectId);
            project = await projectRes.json();
            
            // Load all setups
            const setupsRes = await fetch('/api/setups');
            allSetups = await setupsRes.json();
            
            // Load instruments for setup details
            const instrumentsRes = await fetch('/api/instruments');
            const allInstruments = await instrumentsRes.json();
            
            // Attach instrument details to setups
            allSetups.forEach(setup => {
                setup.instrumentDetails = (setup.instrumentIds || []).map(iid => {
                    return allInstruments.find(i => i.id === iid);
                }).filter(i => i);
            });
            
            assignedSetupIds = project.setupIds || [];
            
            displayProjectInfo();
            updateSetupLists();
        } catch (error) {
            console.error('Error loading data:', error);
            showToast('Failed to load data: ' + error.message, 'error');
        }
    }

    function displayProjectInfo() {
        document.getElementById('projectName').textContent = project.name || 'Unnamed Project';
        document.getElementById('projectDescription').textContent = project.description || 'No description';
        
        if (project.customerName) {
            document.getElementById('projectCustomer').innerHTML = 
                '<i class="bi bi-person-badge"></i> <strong>' + project.customerName + '</strong>' + 
                (project.customerCompany ? ' - ' + project.customerCompany : '');
        }
    }

    function updateSetupLists() {
        availableSetups = allSetups.filter(s => !assignedSetupIds.includes(s.id));
        const assigned = allSetups.filter(s => assignedSetupIds.includes(s.id));
        
        renderAvailableSetups(availableSetups);
        renderAssignedSetups(assigned);
        
        document.getElementById('assignedCount').textContent = assigned.length;
    }

    function renderAvailableSetups(setups) {
        const container = document.getElementById('availableSetups');
        
        if (setups.length === 0) {
            container.innerHTML = '<div style="text-align:center;color:#94a3b8;padding:2rem;">No available setups</div>';
            return;
        }
        
        let html = '';
        setups.forEach(s => {
            const isSelected = selectedAvailable.has(s.id);
            const instrumentCount = (s.instrumentDetails || []).length;
            
            html += '<div class="setup-item ' + (isSelected ? 'selected' : '') + '" onclick="toggleAvailableSelection(\'' + s.id + '\')">' +
                    '<h6><i class="bi bi-diagram-3"></i> ' + (s.name || 'Unnamed') + '</h6>' +
                    '<div class="setup-type"><i class="bi bi-tag"></i> ' + (s.type || 'N/A') + '</div>' +
                    '<div class="instrument-count"><i class="bi bi-gear"></i> ' + instrumentCount + ' instrument(s)</div>' +
                    '</div>';
        });
        
        container.innerHTML = html;
    }

    function renderAssignedSetups(setups) {
        const container = document.getElementById('assignedSetups');
        
        if (setups.length === 0) {
            container.innerHTML = '<div style="text-align:center;color:#94a3b8;padding:2rem;">No assigned setups</div>';
            return;
        }
        
        let html = '';
        setups.forEach(s => {
            const isSelected = selectedAssigned.has(s.id);
            const instrumentCount = (s.instrumentDetails || []).length;
            
            html += '<div class="setup-item ' + (isSelected ? 'selected' : '') + '" onclick="toggleAssignedSelection(\'' + s.id + '\')">' +
                    '<h6><i class="bi bi-check-circle-fill" style="color:#10b981;"></i> ' + (s.name || 'Unnamed') + '</h6>' +
                    '<div class="setup-type"><i class="bi bi-tag"></i> ' + (s.type || 'N/A') + '</div>' +
                    '<div class="instrument-count"><i class="bi bi-gear"></i> ' + instrumentCount + ' instrument(s)</div>' +
                    '</div>';
        });
        
        container.innerHTML = html;
    }

    function toggleAvailableSelection(setupId) {
        if (selectedAvailable.has(setupId)) {
            selectedAvailable.delete(setupId);
        } else {
            selectedAvailable.add(setupId);
        }
        updateSetupLists();
    }

    function toggleAssignedSelection(setupId) {
        if (selectedAssigned.has(setupId)) {
            selectedAssigned.delete(setupId);
        } else {
            selectedAssigned.add(setupId);
        }
        updateSetupLists();
    }

    function assignSelected() {
        if (selectedAvailable.size === 0) {
            showToast('Please select setups to assign', 'warning');
            return;
        }
        
        selectedAvailable.forEach(id => {
            if (!assignedSetupIds.includes(id)) {
                assignedSetupIds.push(id);
            }
        });
        
        selectedAvailable.clear();
        updateSetupLists();
    }

    function unassignSelected() {
        if (selectedAssigned.size === 0) {
            showToast('Please select setups to remove', 'warning');
            return;
        }
        
        selectedAssigned.forEach(id => {
            const index = assignedSetupIds.indexOf(id);
            if (index > -1) {
                assignedSetupIds.splice(index, 1);
            }
        });
        
        selectedAssigned.clear();
        updateSetupLists();
    }

    async function saveChanges() {
        try {
            const updatedProject = {
                ...project,
                setupIds: assignedSetupIds
            };
            
            const response = await fetch('/api/projects/' + projectId, {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(updatedProject)
            });
            
            if (!response.ok) {
                throw new Error('Failed to update project');
            }
            
            showToast('Resources updated successfully!', 'success');
            setTimeout(function() { window.location.href = '/Projects'; }, 1000);
        } catch (error) {
            console.error('Error saving changes:', error);
            showToast('Failed to save changes: ' + error.message, 'error');
        }
    }

    // Setup search functionality
    document.addEventListener('DOMContentLoaded', function() {
        const searchInput = document.getElementById('setupSearch');
        if (searchInput) {
            searchInput.addEventListener('input', function(e) {
                const searchTerm = e.target.value.toLowerCase();
                const filtered = allSetups.filter(s => 
                    !assignedSetupIds.includes(s.id) &&
                    ((s.name || '').toLowerCase().includes(searchTerm) ||
                     (s.type || '').toLowerCase().includes(searchTerm))
                );
                renderAvailableSetups(filtered);
            });
        }
    });
</script>
