                    '<button onclick="addOperation(' + groupIndex + ', ' + tcIndex + ', \'teardown\')" ' +
                        'style="width:100%;margin-top:0.5rem;padding:0.5rem;background:white;border:2px dashed #fca5a5;border-radius:6px;color:#991b1b;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:0.5rem;font-size:0.75rem;transition:all 0.2s;" ' +
