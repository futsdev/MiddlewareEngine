    // Function-level operations
    let draggedFunction = null;
    
    function dragFunctionStart(e, groupIndex, tcIndex, funcIndex) {
        draggedFunction = { groupIndex, tcIndex, funcIndex };
        e.stopPropagation();
    }
    
    function allowFunctionDrop(e) {
        e.preventDefault();
        e.stopPropagation();
    }
    
    function dropFunction(e, targetGroupIndex, targetTcIndex, targetFuncIndex) {
        e.preventDefault();
        e.stopPropagation();
        
        if (!draggedFunction) return;
        
        const { groupIndex: srcGrp, tcIndex: srcTc, funcIndex: srcFunc } = draggedFunction;
        const functions = campaign.testGroups[srcGrp].testCaseExecutions[srcTc].functions;
        
        // Remove from source
        const [movedFunc] = functions.splice(srcFunc, 1);
        
        // Insert at target
        const targetFunctions = campaign.testGroups[targetGroupIndex].testCaseExecutions[targetTcIndex].functions;
        targetFunctions.splice(targetFuncIndex, 0, movedFunc);
        
        // Update orders
        targetFunctions.forEach((f, idx) => f.order = idx);
        
        draggedFunction = null;
        renderTree();
    }
    
