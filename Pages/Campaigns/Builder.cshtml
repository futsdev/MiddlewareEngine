                        '<button class="btn-icon" onclick="event.stopPropagation();openSectionInstrumentSelector(' + groupIndex + ', ' + tcIndex + ', \'teardown\')" style="font-size:0.65rem;padding:0.2rem 0.4rem;background:#10b981;color:white;border:none;border-radius:4px;" title="Change Instrument">' +
                            '<i class="bi bi-arrow-repeat"></i>' +
