        return html;
    }
    
    function toggleHierarchySection(groupIndex, tcIndex, type, stepIdx, actionIdx) {
        event.stopPropagation();
        const tc = campaign.testGroups[groupIndex].testCaseExecutions[tcIndex];
        
        if (!tc.collapseStates) {
            tc.collapseStates = { setup: false, teardown: false, postTestCleanup: false, steps: {}, actions: {} };
        }
        
        switch(type) {
            case 'setup':
                tc.collapseStates.setup = !tc.collapseStates.setup;
                break;
            case 'teardown':
                tc.collapseStates.teardown = !tc.collapseStates.teardown;
                break;
            case 'postTestCleanup':
                tc.collapseStates.postTestCleanup = !tc.collapseStates.postTestCleanup;
                break;
            case 'step':
                const stepKey = 'step-' + stepIdx;
                tc.collapseStates.steps[stepKey] = !tc.collapseStates.steps[stepKey];
                break;
            case 'action':
                const actionKey = 'action-' + stepIdx + '-' + actionIdx;
                tc.collapseStates.actions[actionKey] = !tc.collapseStates.actions[actionKey];
                break;
            case 'pre':
                const preKey = 'pre-' + stepIdx + '-' + actionIdx;
                tc.collapseStates.actions[preKey] = !tc.collapseStates.actions[preKey];
                break;
            case 'ops':
                const opsKey = 'ops-' + stepIdx + '-' + actionIdx;
                tc.collapseStates.actions[opsKey] = !tc.collapseStates.actions[opsKey];
                break;
            case 'post':
                const postKey = 'post-' + stepIdx + '-' + actionIdx;
                tc.collapseStates.actions[postKey] = !tc.collapseStates.actions[postKey];
                break;
        }
        
        renderTree();
    }
    
    function renderOperation(operation, groupIndex, tcIndex, section, opIndex) {
        const opId = section + '-' + opIndex;
        
        // Get function definition from multiple sources
        const funcDefFromId = operation.functionDefinitionId || operation.FunctionDefinitionId || operation.function_definition_id 
            ? allFunctions.find(f => f.id === (operation.functionDefinitionId || operation.FunctionDefinitionId || operation.function_definition_id)) 
            : null;
        const funcDefNested = operation.function_definition || operation.FunctionDefinition || operation.functionDefinition;
        const funcDef = funcDefFromId || funcDefNested;
        
        // Get operation name from multiple sources
        const opName = operation.name || operation.Name || operation.function_name || operation.FunctionName || 
                      funcDef?.name || funcDef?.Name || operation.operationType || 'Operation';
        
        // Get execution type (REST API, SCPI, SDK Method) - check all variants
        const executionType = operation.executionType || operation.ExecutionType || operation.execution_type ||
                             funcDef?.executionType || funcDef?.ExecutionType || funcDef?.execution_type || 'unknown';
        
        // Get operation type (READ, WRITE, FILEUPLOAD, FILEDOWNLOAD) - check all variants
        const operationType = operation.operationType || operation.OperationType || operation.operation_type ||
                             funcDef?.operationType || funcDef?.OperationType || funcDef?.operation_type || 'READ';
        
        const params = operation.parameters || operation.Parameters || operation.parameter_overrides || operation.ParameterOverrides || {};
        const paramCount = Object.keys(params).length;
        const hasParams = paramCount > 0;
        
        // Execution Type badge color (REST, SCPI, SDK)
        let executionBadge = '';
        switch(executionType.toLowerCase()) {
            case 'restapi': 
                executionBadge = '<span style="background:#10b981;color:white;padding:0.15rem 0.4rem;border-radius:4px;font-size:0.7rem;font-weight:600;display:inline-flex;align-items:center;gap:0.2rem;"><i class="bi bi-globe"></i> REST</span>'; 
                break;
            case 'scpi': 
                executionBadge = '<span style="background:#3b82f6;color:white;padding:0.15rem 0.4rem;border-radius:4px;font-size:0.7rem;font-weight:600;display:inline-flex;align-items:center;gap:0.2rem;"><i class="bi bi-cpu"></i> SCPI</span>'; 
                break;
            case 'sdkmethod': 
                executionBadge = '<span style="background:#8b5cf6;color:white;padding:0.15rem 0.4rem;border-radius:4px;font-size:0.7rem;font-weight:600;display:inline-flex;align-items:center;gap:0.2rem;"><i class="bi bi-code-square"></i> SDK</span>'; 
                break;
            default: 
                executionBadge = '<span style="background:#64748b;color:white;padding:0.15rem 0.4rem;border-radius:4px;font-size:0.7rem;font-weight:600;">' + executionType.toUpperCase() + '</span>';
        }
        
        // Operation Type badge color (READ, WRITE, FILEUPLOAD, FILEDOWNLOAD)
        let operationBadge = '';
        switch(operationType.toUpperCase()) {
            case 'READ': 
                operationBadge = '<span style="background:#3b82f6;color:white;padding:0.15rem 0.4rem;border-radius:4px;font-size:0.7rem;font-weight:600;display:inline-flex;align-items:center;gap:0.2rem;"><i class="bi bi-eye-fill"></i> READ</span>'; 
                break;
            case 'WRITE': 
                operationBadge = '<span style="background:#f97316;color:white;padding:0.15rem 0.4rem;border-radius:4px;font-size:0.7rem;font-weight:600;display:inline-flex;align-items:center;gap:0.2rem;"><i class="bi bi-pencil-fill"></i> WRITE</span>'; 
                break;
            case 'FILEUPLOAD': 
                operationBadge = '<span style="background:#10b981;color:white;padding:0.15rem 0.4rem;border-radius:4px;font-size:0.7rem;font-weight:600;display:inline-flex;align-items:center;gap:0.2rem;"><i class="bi bi-cloud-upload-fill"></i> UPLOAD</span>'; 
                break;
            case 'FILEDOWNLOAD': 
                operationBadge = '<span style="background:#a855f7;color:white;padding:0.15rem 0.4rem;border-radius:4px;font-size:0.7rem;font-weight:600;display:inline-flex;align-items:center;gap:0.2rem;"><i class="bi bi-cloud-download-fill"></i> DOWNLOAD</span>'; 
                break;
            default: 
                operationBadge = '<span style="background:#64748b;color:white;padding:0.15rem 0.4rem;border-radius:4px;font-size:0.7rem;font-weight:600;">' + operationType.toUpperCase() + '</span>';
        }
        
        const paramBadge = hasParams ? 
            '<span style="background:#dcfce7;color:#166534;padding:0.15rem 0.4rem;border-radius:4px;font-size:0.7rem;font-weight:600;display:inline-flex;align-items:center;gap:0.2rem;"><i class="bi bi-sliders"></i> ' + paramCount + '</span>' :
            '<span style="background:#f3f4f6;color:#6b7280;padding:0.15rem 0.4rem;border-radius:4px;font-size:0.7rem;font-weight:600;">0</span>';
        
        return '<div class="operation-node" style="background:white;border:1px solid #e2e8f0;border-radius:6px;padding:0.5rem;margin-bottom:0.3rem;font-size:0.75rem;transition:all 0.2s;box-shadow:0 1px 2px rgba(0,0,0,0.05);" ' +
                'onmouseover="this.style.background=\'#f8fafc\';this.style.borderColor=\'#3b82f6\';this.style.boxShadow=\'0 4px 6px rgba(59,130,246,0.1)\';" ' +
                'onmouseout="this.style.background=\'white\';this.style.borderColor=\'#e2e8f0\';this.style.boxShadow=\'0 1px 2px rgba(0,0,0,0.05)\';">' +
                '<div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.4rem;">' +
                    '<div style="width:1.4rem;height:1.4rem;background:linear-gradient(135deg,#3b82f6 0%,#2563eb 100%);color:white;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.7rem;font-weight:700;box-shadow:0 2px 4px rgba(59,130,246,0.3);">' + (opIndex + 1) + '</div>' +
                    '<div style="flex:1;font-weight:600;color:#1e293b;font-size:0.8rem;">' + opName + '</div>' +
                    '<button class="btn-icon btn-edit" onclick="event.stopPropagation();selectOperation(' + groupIndex + ', ' + tcIndex + ', \'' + section + '\', ' + opIndex + ')" style="font-size:0.7rem;padding:0.2rem 0.3rem;" title="Properties">' +
                        '<i class="bi bi-gear"></i>' +
                    '</button>' +
                    '<button class="btn-icon" onclick="event.stopPropagation();moveOperation(' + groupIndex + ', ' + tcIndex + ', \'' + section + '\', ' + opIndex + ', -1)" style="font-size:0.7rem;padding:0.15rem 0.25rem;" title="Move Up">' +
                        '<i class="bi bi-arrow-up"></i>' +
                    '</button>' +
                    '<button class="btn-icon" onclick="event.stopPropagation();moveOperation(' + groupIndex + ', ' + tcIndex + ', \'' + section + '\', ' + opIndex + ', 1)" style="font-size:0.7rem;padding:0.15rem 0.25rem;" title="Move Down">' +
                        '<i class="bi bi-arrow-down"></i>' +
                    '</button>' +
                '</div>' +
                '<div style="display:flex;align-items:center;gap:0.4rem;flex-wrap:wrap;">' +
                    '<div style="display:flex;align-items:center;gap:0.3rem;padding:0.2rem 0.4rem;background:#f8fafc;border-radius:4px;">' +
                        '<span style="font-size:0.65rem;color:#64748b;font-weight:600;">EXECUTION:</span>' +
                        executionBadge +
                    '</div>' +
                    '<div style="display:flex;align-items:center;gap:0.3rem;padding:0.2rem 0.4rem;background:#f8fafc;border-radius:4px;">' +
                        '<span style="font-size:0.65rem;color:#64748b;font-weight:600;">OPERATION:</span>' +
                        operationBadge +
                    '</div>' +
                    '<div style="display:flex;align-items:center;gap:0.3rem;padding:0.2rem 0.4rem;background:#f8fafc;border-radius:4px;">' +
                        '<span style="font-size:0.65rem;color:#64748b;font-weight:600;">PARAMS:</span>' +
                        paramBadge +
                    '</div>' +
                '</div>' +
            '</div>';
    }
    
    function renderFunctions(testCase, groupIndex, tcIndex) {
        if (!testCase.functions || testCase.functions.length === 0) {
            return '<div class="function-node">' +
                    '<div style="padding:0.75rem;text-align:center;color:#94a3b8;font-size:0.8125rem;">' +
                        '<i class="bi bi-inbox"></i> No functions yet' +
                        '<button class="btn btn-sm btn-primary" onclick="addFunctionToTestCase(' + groupIndex + ', ' + tcIndex + ')" style="margin-top:0.5rem;">' +
                            '<i class="bi bi-plus-circle"></i> Add Function' +
                        '</button>' +
                    '</div>' +
                '</div>';
        }

        return testCase.functions.map((func, funcIndex) => {
            const functionDef = func.functionId ? allFunctions.find(f => f.id === func.functionId) : null;
            const statusClass = func.enabled ? 'status-enabled' : 'status-disabled';
            const toggleIcon = func.enabled ? 'toggle-on' : 'toggle-off';
            const toggleDisabled = !func.enabled ? 'disabled' : '';
            const paramCount = functionDef?.parameters?.length || 0;
            const hasOverrides = func.parameterOverrides && Object.keys(func.parameterOverrides).length > 0;
            const paramBadge = paramCount > 0 ? '<span style="background:' + (hasOverrides ? '#dcfce7' : '#f3f4f6') + ';color:' + (hasOverrides ? '#166534' : '#6b7280') + ';padding:0.125rem 0.375rem;border-radius:4px;font-size:0.625rem;margin-left:0.25rem;font-weight:600;">' + (hasOverrides ? '✓ ' : '') + paramCount + ' params</span>' : '';
            
            // Inline operation badge
            const inlineBadge = func.isInline ? '<span style="background:#fef08a;color:#854d0e;padding:0.125rem 0.375rem;border-radius:4px;font-size:0.625rem;margin-left:0.25rem;font-weight:600;">⚠️ Inline</span>' : '';
            
            // Source type badge with color coding
            const sourceType = func.sourceType || 'Main';
            const sourceColors = {
                'Setup': { bg: '#fef3c7', color: '#92400e', icon: '⚙️' },
                'PreCondition': { bg: '#dbeafe', color: '#1e40af', icon: '📋' },
                'Main': { bg: '#dcfce7', color: '#166534', icon: '▶️' },
                'PostCondition': { bg: '#e0e7ff', color: '#3730a3', icon: '✓' },
                'Teardown': { bg: '#fce7f3', color: '#831843', icon: '🔚' }
            };
            const srcColor = sourceColors[sourceType] || sourceColors.Main;
            const sourceBadge = '<span style="background:' + srcColor.bg + ';color:' + srcColor.color + ';padding:0.125rem 0.375rem;border-radius:4px;font-size:0.625rem;margin-right:0.25rem;font-weight:600;">' + srcColor.icon + ' ' + sourceType + '</span>';
            
            const executionType = func.isInline ? func.operationType : (functionDef?.executionType || 'Unknown');
            const operationType = func.isInline ? (func.operationType || 'Unknown') : (functionDef?.operationType || 'READ');
            
            return '<div class="tree-node function-node" draggable="true" ' +
                     'ondragstart="dragFunctionStart(event, ' + groupIndex + ', ' + tcIndex + ', ' + funcIndex + ')" ' +
                     'ondragover="allowFunctionDrop(event)" ' +
                     'ondrop="dropFunction(event, ' + groupIndex + ', ' + tcIndex + ', ' + funcIndex + ')">' +
                    '<div class="tree-node-content">' +
                        '<div class="function-header">' +
                            '<span class="drag-handle"><i class="bi bi-grip-vertical"></i></span>' +
                            '<div class="function-icon">' + (funcIndex + 1) + '</div>' +
                            '<div class="status-indicator ' + statusClass + '"></div>' +
                            '<div class="function-info">' +
                                '<h6 class="function-name">' + sourceBadge + (func.functionName || 'Unknown') + paramBadge + inlineBadge + '</h6>' +
                                '<div class="function-type">' + executionType + ' • ' + operationType + '</div>' +
                            '</div>' +
                            '<div class="function-controls">' +
                                '<button class="btn-icon btn-toggle ' + toggleDisabled + '" ' +
                                        'onclick="toggleFunctionEnabled(' + groupIndex + ', ' + tcIndex + ', ' + funcIndex + ')" ' +
                                        'title="Enable/Disable" ' +
                                        'style="width:24px;height:24px;">' +
                                    '<i class="bi bi-' + toggleIcon + '" style="font-size:0.75rem;"></i>' +
                                '</button>' +
                                '<button class="btn-icon btn-edit" ' +
                                        'onclick="selectFunction(' + groupIndex + ', ' + tcIndex + ', ' + funcIndex + ')" ' +
                                        'title="Edit Parameters" ' +
                                        'style="width:24px;height:24px;">' +
                                    '<i class="bi bi-sliders" style="font-size:0.75rem;"></i>' +
                                '</button>' +
                                '<button class="btn-icon btn-delete" ' +
                                        'onclick="deleteFunction(' + groupIndex + ', ' + tcIndex + ', ' + funcIndex + ')" ' +
                                        'title="Remove" ' +
                                        'style="width:24px;height:24px;">' +
                                    '<i class="bi bi-x-circle" style="font-size:0.75rem;"></i>' +
                                '</button>' +
                            '</div>' +
                        '</div>' +
                    '</div>' +
                '</div>';
        }).join('') + 
            '<div class="function-node">' +
                '<button class="btn btn-sm btn-outline-primary" onclick="addFunctionToTestCase(' + groupIndex + ', ' + tcIndex + ')" style="width:100%;">' +
                    '<i class="bi bi-plus-circle"></i> Add Function' +
                '</button>' +
            '</div>';
    }

    function allowDrop(e) {
        e.preventDefault();
        e.currentTarget.classList.add('drag-over');
    }

    async function dropTestCase(e, groupIndex) {
        e.preventDefault();
        e.currentTarget.classList.remove('drag-over');
        
        if (!draggedTestCase) {
            console.log('❌ No dragged test case found');
            return;
        }

        console.log('🔵 Dropping test case:', draggedTestCase, 'into group', groupIndex);
        const testCase = allTestCases.find(tc => tc.id === draggedTestCase);
        
        if (!testCase) {
            console.error('❌ Test case not found in allTestCases:', draggedTestCase);
            showToast('Test case not found', 'error');
            return;
        }
        
        if (!campaign.testGroups[groupIndex].testCaseExecutions) {
            campaign.testGroups[groupIndex].testCaseExecutions = [];
        }
        
        console.log('✅ ALLOWING DUPLICATE - No validation check');
        // Allow same test case multiple times - no duplicate check

        // Fetch full test case details including all functions
        try {
            const testCaseDetails = await fetch(`/api/testcases/${testCase.id}`).then(r => r.json());
            
            console.log('Test Case Details:', testCaseDetails);
            
            // Helper function to enrich operations with full function definitions
            async function enrichOperationsWithFunctionDefs(operations) {
                if (!operations || !Array.isArray(operations)) return operations;
                
                const enrichedOps = [];
                for (const op of operations) {
                    const funcDefId = op.functionDefinitionId || op.FunctionDefinitionId || op.function_definition_id;
                    
                    if (funcDefId) {
                        // Find function definition and embed it
                        const funcDef = allFunctions.find(f => f.id === funcDefId);
                        if (funcDef) {
                            console.log(`✓ Embedding function definition: ${funcDef.name}`);
                            enrichedOps.push({
                                ...op,
                                function_definition: funcDef,
                                FunctionDefinition: funcDef,
                                functionDefinition: funcDef
                            });
                        } else {
                            console.warn(`Function definition not found for ID: ${funcDefId}`);
                            enrichedOps.push(op);
                        }
                    } else {
                        // Inline operation without function definition
                        enrichedOps.push(op);
                    }
                }
                return enrichedOps;
            }
            
            // Enrich all operations in the test case structure
            if (testCaseDetails.SetupOperations) {
                testCaseDetails.SetupOperations = await enrichOperationsWithFunctionDefs(testCaseDetails.SetupOperations);
            }
            if (testCaseDetails.setupOperations) {
                testCaseDetails.setupOperations = await enrichOperationsWithFunctionDefs(testCaseDetails.setupOperations);
            }
            if (testCaseDetails.TeardownOperations) {
                testCaseDetails.TeardownOperations = await enrichOperationsWithFunctionDefs(testCaseDetails.TeardownOperations);
            }
            if (testCaseDetails.teardownOperations) {
                testCaseDetails.teardownOperations = await enrichOperationsWithFunctionDefs(testCaseDetails.teardownOperations);
            }
            
            // Enrich nested structure: Teardown.Operations and Cleanup.Operations
            if (testCaseDetails.Teardown?.Operations) {
                testCaseDetails.Teardown.Operations = await enrichOperationsWithFunctionDefs(testCaseDetails.Teardown.Operations);
            }
            if (testCaseDetails.teardown?.operations) {
                testCaseDetails.teardown.operations = await enrichOperationsWithFunctionDefs(testCaseDetails.teardown.operations);
            }
            if (testCaseDetails.Cleanup?.Operations) {
                testCaseDetails.Cleanup.Operations = await enrichOperationsWithFunctionDefs(testCaseDetails.Cleanup.Operations);
            }
            if (testCaseDetails.cleanup?.operations) {
                testCaseDetails.cleanup.operations = await enrichOperationsWithFunctionDefs(testCaseDetails.cleanup.operations);
            }
            if (testCaseDetails.PostTestCleanup) {
                testCaseDetails.PostTestCleanup = await enrichOperationsWithFunctionDefs(testCaseDetails.PostTestCleanup);
            }
            if (testCaseDetails.postTestCleanup) {
                testCaseDetails.postTestCleanup = await enrichOperationsWithFunctionDefs(testCaseDetails.postTestCleanup);
            }
            
            // Enrich steps operations
            const steps = testCaseDetails.steps || testCaseDetails.Steps || [];
            if (steps && Array.isArray(steps)) {
                for (const step of steps) {
                    const actions = step.actions || step.Actions || [];
                    if (actions && Array.isArray(actions)) {
                        for (const action of actions) {
                            if (action.preConditions) {
                                action.preConditions = await enrichOperationsWithFunctionDefs(action.preConditions);
                            }
                            if (action.PreConditions) {
                                action.PreConditions = await enrichOperationsWithFunctionDefs(action.PreConditions);
                            }
                            if (action.operations) {
                                action.operations = await enrichOperationsWithFunctionDefs(action.operations);
                            }
                            if (action.Operations) {
                                action.Operations = await enrichOperationsWithFunctionDefs(action.Operations);
                            }
                            if (action.postConditions) {
                                action.postConditions = await enrichOperationsWithFunctionDefs(action.postConditions);
                            }
                            if (action.PostConditions) {
                                action.PostConditions = await enrichOperationsWithFunctionDefs(action.PostConditions);
                            }
                        }
                    }
                }
            }
            
            console.log('✅ Enriched test case with function definitions');
            
            // Extract all operations from test case structure
            const functions = [];
            let order = 0;
            const baseId = Date.now().toString() + '_' + Math.random().toString(36).substr(2, 9);
            
            // Helper function to extract operations from any array
            function extractOperations(operations, source, sourceType) {
                if (operations && Array.isArray(operations)) {
                    console.log(`Extracting ${operations.length} operations from ${source}:`, operations);
                    for (const op of operations) {
                        const funcDefId = op.functionDefinitionId || op.FunctionDefinitionId;
                        
                        if (!funcDefId) {
                            console.warn(`⚠️ Operation in ${source} has no functionDefinitionId:`, op);
                            console.warn(`   - Name: ${op.name || 'Unnamed'}`);
                            console.warn(`   - Type: ${op.operationType || 'Unknown'}`);
                            console.warn(`   - Has OperationDetails: ${op.operationDetails || op.OperationDetails ? 'Yes' : 'No'}`);
                            
                            // For inline operations without functionDefinitionId, create a placeholder
                            if (op.name || op.operationType) {
                                console.log(`Creating placeholder for inline operation: ${op.name || op.operationType}`);
                                functions.push({
                                    id: baseId + '_' + order,
                                    functionId: null,
                                    functionName: op.name || `${op.operationType || 'Unknown'} Operation`,
                                    sourceType: sourceType,
                                    operationType: op.operationType,
                                    isInline: true,
                                    inlineDetails: op.operationDetails || op.OperationDetails || {},
                                    order: order++,
                                    parameterOverrides: op.parameters || op.Parameters || {},
                                    enabled: true
                                });
                            }
                            continue;
                        }
                        
                        const func = allFunctions.find(f => f.id === funcDefId);
                        if (func) {
                            console.log(`✓ Found function: ${func.name} (ID: ${funcDefId}) from ${sourceType}`);
                            functions.push({
                                id: baseId + '_' + order,
                                functionId: funcDefId,
                                functionName: func.name,
                                sourceType: sourceType,
                                order: order++,
                                parameterOverrides: op.parameters || op.Parameters || {},
                                enabled: true
                            });
                        } else {
                            console.error(`❌ Function not found for ID: ${funcDefId}`);
                        }
                    }
                } else {
                    console.log(`No operations found in ${source}`);
                }
            }
            
            // Extract from Setup Operations (root level)
            extractOperations(testCaseDetails.setupOperations || testCaseDetails.SetupOperations, 'SetupOperations', 'Setup');
            
            // Extract from Steps -> Actions -> Operations/PreConditions/PostConditions
            // Reuse steps variable from enrichment section above
            if (steps && Array.isArray(steps)) {
                for (const step of steps) {
                    const actions = step.actions || step.Actions || [];
                    if (actions && Array.isArray(actions)) {
                        for (const action of actions) {
                            // Extract from PreConditions
                            extractOperations(action.preConditions || action.PreConditions, 'PreConditions', 'PreCondition');
                            
                            // Extract from Operations
                            extractOperations(action.operations || action.Operations, 'Operations', 'Main');
                            
                            // Extract from PostConditions
                            extractOperations(action.postConditions || action.PostConditions, 'PostConditions', 'PostCondition');
                        }
                    }
                }
            }
            
            // Extract from Teardown Operations (root level)
            extractOperations(testCaseDetails.teardownOperations || testCaseDetails.TeardownOperations, 'TeardownOperations', 'Teardown');
            
            console.log(`Total functions extracted: ${functions.length}`);
            
            // Generate truly unique ID using timestamp + random value
            const uniqueId = Date.now().toString() + '_' + Math.random().toString(36).substr(2, 9);
            
            const newTestCase = {
                id: uniqueId,
                functionId: testCase.functionId || testCase.id,
                testCaseId: testCase.id, // Store for hierarchical view
                testCaseDefinition: testCaseDetails, // Store complete test case definition for hierarchical operations
                functionName: testCase.name,
                order: campaign.testGroups[groupIndex].testCaseExecutions.length,
                retryCount: 0,
                delaySeconds: 0,
                abortOnFailure: true,
                enabled: true,
                parameterOverrides: {},
                expectedResult: null,
                sectionInstruments: {},
                functions: functions,
                collapseStates: {
                    setup: true,
                    teardown: true,
                    postTestCleanup: true,
                    steps: {},
                    actions: {}
                }
            };

            campaign.testGroups[groupIndex].testCaseExecutions.push(newTestCase);
            renderTree();
            showToast(`Added "${testCase.name}" (Instance ${campaign.testGroups[groupIndex].testCaseExecutions.filter(t => t.testCaseId === testCase.id).length})`, 'success');
        } catch (error) {
            console.error('Failed to load test case details:', error);
            showToast('Failed to load test case details', 'error');
        }
    }

