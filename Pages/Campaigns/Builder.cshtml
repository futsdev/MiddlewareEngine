@section Scripts {
<script>
    const campaignId = '@Model.Id';
    let campaign = null;
    let allTestCases = [];
    let allFunctions = [];
    let allProjects = [];
    let allSetups = [];
    let allInstruments = [];
    let selectedNode = null;
    let draggedTestCase = null;
    let propertiesPanelOpen = true;
    let setupInstrumentsExpanded = false;

    // Centralized configuration for Execution Types and Operation Types
    const EXECUTION_TYPES = [
        { value: 'RestApi', label: '🌐 REST API' },
        { value: 'ScpiCommand', label: '⚡ SCPI Command' },
        { value: 'SdkMethod', label: '📦 SDK Method' },
        { value: 'SSH', label: '🔐 SSH' }
    ];

    const OPERATION_TYPES = [
        { value: 'READ', label: '📖 READ' },
        { value: 'WRITE', label: '✏️ WRITE' },
        { value: 'FILEUPLOAD', label: '⬆️ FILE UPLOAD' },
        { value: 'FILEDOWNLOAD', label: '⬇️ FILE DOWNLOAD' }
    ];

    document.addEventListener('DOMContentLoaded', async function() {
        await loadData();
        setupDragAndDrop();
        updateFloatingToggle();
    });

    async function loadData() {
        try {
            [campaign, allTestCases, allFunctions, allProjects, allSetups, allInstruments] = await Promise.all([
                fetch(`/api/campaigns/${campaignId}`).then(r => r.json()),
                fetch('/api/testcases').then(r => r.json()),
                fetch('/api/functions').then(r => r.json()),
                fetch('/api/projects').then(r => r.json()),
                fetch('/api/setups').then(r => r.json()),
                fetch('/api/instruments').then(r => r.json())
            ]);

            // Normalize campaign data from PascalCase (C#) to camelCase (JavaScript)
            campaign = normalizeCampaignData(campaign);
            
            console.log('Loaded campaign:', campaign);
            if (campaign.testGroups && campaign.testGroups[0]) {
                console.log('Test Group 0 setupIds:', campaign.testGroups[0].setupIds);
                if (campaign.testGroups[0].testCaseExecutions && campaign.testGroups[0].testCaseExecutions[0]) {
                    console.log('Test Case 0 sectionInstruments:', campaign.testGroups[0].testCaseExecutions[0].sectionInstruments);
                }
            }

            updateCampaignHeader();
            renderLibrary();
            renderTree();
        } catch (error) {
            console.error('Error loading campaign data:', error);
            showToast('Failed to load campaign data', 'error');
        }
    }
    
    function normalizeCampaignData(data) {
        // Convert from C# PascalCase to JavaScript camelCase
        const normalized = {
            id: data.Id || data.id,
            name: data.Name || data.name,
            description: data.Description || data.description,
            projectId: data.ProjectId || data.project_id || data.projectId,
            setupIds: data.SetupIds || data.setup_ids || data.setupIds || [],
            status: data.Status || data.status || 'Draft',
            createdAt: data.CreatedAt || data.created_at || data.createdAt,
            updatedAt: data.UpdatedAt || data.updated_at || data.updatedAt,
            tags: data.Tags || data.tags || [],
            testGroups: []
        };
        
        // Normalize test groups
        if (data.TestGroups || data.test_groups || data.testGroups) {
            const groups = data.TestGroups || data.test_groups || data.testGroups;
            normalized.testGroups = groups.map(group => ({
                id: group.Id || group.id,
                name: group.Name || group.name,
                description: group.Description || group.description || '',
                order: group.Order || group.order,
                retryCount: group.RetryCount ?? group.retry_count ?? group.retryCount ?? 0,
                delaySeconds: group.DelaySeconds ?? group.delay_seconds ?? group.delaySeconds ?? 0,
                abortOnFailure: group.AbortOnFailure ?? group.abort_on_failure ?? group.abortOnFailure ?? true,
                enabled: group.Enabled ?? group.enabled ?? true,
                setupIds: group.SetupIds || group.setup_ids || group.setupIds || [],
                testCaseExecutions: (group.TestCaseExecutions || group.test_case_executions || group.testCaseExecutions || []).map(tc => {
                    const normalized = {
                        id: tc.Id || tc.id,
                        functionId: tc.FunctionId || tc.function_id || tc.functionId,
                        testCaseId: tc.TestCaseId || tc.test_case_id || tc.testCaseId || null,
                        functionName: tc.FunctionName || tc.function_name || tc.functionName,
                        order: tc.Order || tc.order,
                        retryCount: tc.RetryCount ?? tc.retry_count ?? tc.retryCount ?? 0,
                        delaySeconds: tc.DelaySeconds ?? tc.delay_seconds ?? tc.delaySeconds ?? 0,
                        abortOnFailure: tc.AbortOnFailure ?? tc.abort_on_failure ?? tc.abortOnFailure ?? true,
                        enabled: tc.Enabled ?? tc.enabled ?? true,
                        parameterOverrides: tc.ParameterOverrides || tc.parameter_overrides || tc.parameterOverrides || {},
                        expectedResult: tc.ExpectedResult || tc.expected_result || tc.expectedResult || null,
                        functions: tc.Functions || tc.functions || [],
                        testCaseDefinition: tc.TestCaseDefinition || tc.test_case_definition || tc.testCaseDefinition || null,
                        sectionInstruments: {},
                        collapseStates: {
                            setup: true,
                            teardown: true,
                            postTestCleanup: true,
                            steps: {},
                            actions: {}
                        }
                    };
                    
                    // Normalize section instruments
                    const sectionInsts = tc.SectionInstruments || tc.section_instruments || tc.sectionInstruments;
                    if (sectionInsts) {
                        for (const [section, instrument] of Object.entries(sectionInsts)) {
                            if (instrument) {
                                normalized.sectionInstruments[section] = {
                                    setupId: instrument.SetupId || instrument.setup_id || instrument.setupId,
                                    instrumentId: instrument.InstrumentId || instrument.instrument_id || instrument.instrumentId
                                };
                            }
                        }
                    }
                    
                    // Also extract section instruments from TestCaseDefinition if present
                    const tcDef = tc.TestCaseDefinition || tc.test_case_definition || tc.testCaseDefinition;
                    if (tcDef) {
                        // Setup section
                        if (tcDef.Setup || tcDef.setup) {
                            const setup = tcDef.Setup || tcDef.setup;
                            const setupInst = setup.AssignedInstrument || setup.assigned_instrument || setup.assignedInstrument;
                            if (setupInst) {
                                normalized.sectionInstruments.setup = {
                                    setupId: setupInst.SetupId || setupInst.setup_id || setupInst.setupId,
                                    instrumentId: setupInst.InstrumentId || setupInst.instrument_id || setupInst.instrumentId
                                };
                            }
                        }
                        
                        // Teardown section
                        if (tcDef.Teardown || tcDef.teardown) {
                            const teardown = tcDef.Teardown || tcDef.teardown;
                            const teardownInst = teardown.AssignedInstrument || teardown.assigned_instrument || teardown.assignedInstrument;
                            if (teardownInst) {
                                normalized.sectionInstruments.teardown = {
                                    setupId: teardownInst.SetupId || teardownInst.setup_id || teardownInst.setupId,
                                    instrumentId: teardownInst.InstrumentId || teardownInst.instrument_id || teardownInst.instrumentId
                                };
                            }
                        }
                        
                        // Cleanup section
                        if (tcDef.Cleanup || tcDef.cleanup) {
                            const cleanup = tcDef.Cleanup || tcDef.cleanup;
                            const cleanupInst = cleanup.AssignedInstrument || cleanup.assigned_instrument || cleanup.assignedInstrument;
                            if (cleanupInst) {
                                normalized.sectionInstruments.cleanup = {
                                    setupId: cleanupInst.SetupId || cleanupInst.setup_id || cleanupInst.setupId,
                                    instrumentId: cleanupInst.InstrumentId || cleanupInst.instrument_id || cleanupInst.instrumentId
                                };
                            }
                        }
                        
                        // Steps sections
                        if (tcDef.Steps || tcDef.steps) {
                            const steps = tcDef.Steps || tcDef.steps;
                            steps.forEach((step, stepIdx) => {
                                const stepInst = step.AssignedInstrument || step.assigned_instrument || step.assignedInstrument;
                                if (stepInst) {
                                    normalized.sectionInstruments[`step-${stepIdx}`] = {
                                        setupId: stepInst.SetupId || stepInst.setup_id || stepInst.setupId,
                                        instrumentId: stepInst.InstrumentId || stepInst.instrument_id || stepInst.instrumentId
                                    };
                                }
                            });
                        }
                    }
                    
                    return normalized;
                })
            }));
        }
        
        return normalized;
    }
    
    // ========== CAMPAIGN SETUP DRAWER FUNCTIONS ==========
    
    function openSetupDrawer() {
        const drawer = document.getElementById('setupDrawer');
        const overlay = document.getElementById('setupDrawerOverlay');
        drawer.classList.add('active');
        overlay.classList.add('active');
        renderSetupDrawerContent();
    }
    
    function closeSetupDrawer() {
        const drawer = document.getElementById('setupDrawer');
        const overlay = document.getElementById('setupDrawerOverlay');
        drawer.classList.remove('active');
        overlay.classList.remove('active');
    }
    
    // Group Setup Manager Functions
    let currentGroupIndex = null;
    
    function openGroupSetupManager(groupIndex) {
        currentGroupIndex = groupIndex;
        const group = campaign.testGroups[groupIndex];
        
        document.getElementById('groupSetupModalTitle').textContent = `Manage Setups for "${group.name}"`;
        renderGroupSetupContent(groupIndex);
        
        const modal = new bootstrap.Modal(document.getElementById('groupSetupModal'));
        modal.show();
    }
    
    function renderGroupSetupContent(groupIndex) {
        const content = document.getElementById('groupSetupContent');
        const group = campaign.testGroups[groupIndex];
        const groupSetupIds = group.setupIds || [];
        
        // Get campaign-assigned setups only (not project-level setups)
        const campaignSetupIds = campaign.setup_ids || campaign.setupIds || campaign.SetupIds || [];
        const campaignSetups = allSetups.filter(s => campaignSetupIds.includes(s.id || s.Id));
        
        if (campaignSetups.length === 0) {
            content.innerHTML = '<div class="alert alert-info"><i class="bi bi-info-circle"></i> No setups assigned to this campaign. Please assign setups to the campaign first.</div>';
            return;
        }
        
        const assignedSetups = campaignSetups.filter(s => groupSetupIds.includes(s.id || s.Id));
        const availableSetups = campaignSetups.filter(s => !groupSetupIds.includes(s.id || s.Id));
        
        content.innerHTML = `
            <div style="margin-bottom:1.5rem;">
                <div style="background:linear-gradient(135deg,#eff6ff 0%,#dbeafe 100%);border-radius:8px;padding:1rem;border:1px solid #bfdbfe;">
                    <div style="display:flex;align-items:center;gap:1rem;margin-bottom:0.5rem;">
                        <i class="bi bi-info-circle-fill" style="color:#3b82f6;font-size:1.5rem;"></i>
                        <div>
                            <h6 style="margin:0;color:#1e40af;font-weight:700;">Test Group Setup Assignment</h6>
                            <p style="margin:0;font-size:0.875rem;color:#3b82f6;">Select from campaign-assigned setups for this test group</p>
                        </div>
                    </div>
                </div>
            </div>
            
            ${assignedSetups.length > 0 ? `
                <div style="margin-bottom:1.5rem;">
                    <h6 style="color:#059669;font-weight:700;margin-bottom:1rem;display:flex;align-items:center;gap:0.5rem;">
                        <i class="bi bi-check-circle-fill"></i>
                        Assigned Setups (${assignedSetups.length})
                    </h6>
                    <div style="display:grid;gap:0.75rem;">
                        ${assignedSetups.map(setup => renderGroupSetupCard(setup, groupIndex, true)).join('')}
                    </div>
                </div>
            ` : ''}
            
            ${availableSetups.length > 0 ? `
                <div>
                    <h6 style="color:#64748b;font-weight:700;margin-bottom:1rem;display:flex;align-items:center;gap:0.5rem;">
                        <i class="bi bi-plus-circle"></i>
                        Available Campaign Setups (${availableSetups.length})
                    </h6>
                    <div style="display:grid;gap:0.75rem;">
                        ${availableSetups.map(setup => renderGroupSetupCard(setup, groupIndex, false)).join('')}
                    </div>
                </div>
            ` : '<div class="alert alert-success"><i class="bi bi-check-circle"></i> All campaign setups are assigned to this group</div>'}
        `;
    }
    
    function renderGroupSetupCard(setup, groupIndex, isAssigned) {
        const setupId = setup.id || setup.Id;
        const setupName = setup.name || setup.Name;
        const setupType = setup.type || setup.Type || 'General';
        const instrumentIds = setup.instrument_ids || setup.instrumentIds || setup.InstrumentIds || [];
        const instrumentCount = instrumentIds.length;
        
        const bgColor = isAssigned ? '#dcfce7' : '#f8fafc';
        const borderColor = isAssigned ? '#10b981' : '#e2e8f0';
        const iconBg = isAssigned ? 'linear-gradient(135deg,#10b981 0%,#059669 100%)' : 'linear-gradient(135deg,#64748b 0%,#475569 100%)';
        const actionButton = isAssigned 
            ? `<button class="btn btn-sm btn-danger" onclick="removeSetupFromGroup(${groupIndex}, '${setupId}')" style="border-radius:6px;font-size:0.75rem;padding:0.375rem 0.75rem;">
                    <i class="bi bi-dash-circle"></i> Remove
               </button>`
            : `<button class="btn btn-sm btn-success" onclick="addSetupToGroup(${groupIndex}, '${setupId}')" style="border-radius:6px;font-size:0.75rem;padding:0.375rem 0.75rem;">
                    <i class="bi bi-plus-circle"></i> Add
               </button>`;
        
        return `
            <div style="background:${bgColor};border-radius:8px;padding:1rem;border:2px solid ${borderColor};transition:all 0.2s;">
                <div style="display:flex;gap:0.75rem;align-items:center;">
                    <div style="width:48px;height:48px;background:${iconBg};border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                        <i class="bi bi-hdd-network-fill" style="color:white;font-size:1.5rem;"></i>
                    </div>
                    <div style="flex:1;min-width:0;">
                        <h6 style="margin:0 0 0.25rem 0;font-weight:700;color:#0f172a;">${setupName}</h6>
                        <div style="display:flex;gap:1rem;font-size:0.75rem;color:#64748b;">
                            <span><i class="bi bi-tag"></i> ${setupType}</span>
                            <span><i class="bi bi-hdd-stack"></i> ${instrumentCount} Instrument${instrumentCount !== 1 ? 's' : ''}</span>
                        </div>
                    </div>
                    <div>
                        ${actionButton}
                    </div>
                </div>
            </div>
        `;
    }
    
    function addSetupToGroup(groupIndex, setupId) {
        if (!campaign.testGroups[groupIndex].setupIds) {
            campaign.testGroups[groupIndex].setupIds = [];
        }
        
        if (!campaign.testGroups[groupIndex].setupIds.includes(setupId)) {
            campaign.testGroups[groupIndex].setupIds.push(setupId);
            renderGroupSetupContent(groupIndex);
            renderTree();
            showToast('Setup added to test group', 'success');
        }
    }
    
    function removeSetupFromGroup(groupIndex, setupId) {
        if (campaign.testGroups[groupIndex].setupIds) {
            campaign.testGroups[groupIndex].setupIds = campaign.testGroups[groupIndex].setupIds.filter(id => id !== setupId);
            renderGroupSetupContent(groupIndex);
            renderTree();
            showToast('Setup removed from test group', 'success');
        }
    }
    
    // Instrument Selection Functions - Section Level
    let currentInstrumentContext = null;
    
    function getSectionInstrumentInfo(groupIndex, testCaseExecution, section) {
        if (!testCaseExecution.sectionInstruments) {
            testCaseExecution.sectionInstruments = {};
        }
        
        const sectionData = testCaseExecution.sectionInstruments[section];
        if (!sectionData || !sectionData.setupId || !sectionData.instrumentId) {
            return { hasInstrument: false };
        }
        
        const setup = allSetups.find(s => (s.id || s.Id) === sectionData.setupId);
        const instrument = allInstruments.find(i => (i.id || i.Id) === sectionData.instrumentId);
        
        return {
            hasInstrument: true,
            setupId: sectionData.setupId,
            instrumentId: sectionData.instrumentId,
            setupName: setup?.name || setup?.Name || 'Unknown Setup',
            instrumentName: instrument?.name || instrument?.Name || 'Unknown Instrument'
        };
    }
    
    function openSectionInstrumentSelector(groupIndex, tcIndex, section) {
        currentInstrumentContext = { groupIndex, tcIndex, section };
        
        const testCase = campaign.testGroups[groupIndex].testCaseExecutions[tcIndex];
        const sectionNames = {
            'setup': 'Setup Operations',
            'teardown': 'Teardown Operations',
            'cleanup': 'Post-Test Cleanup',
            'steps': 'Step Operations'
        };
        
        document.getElementById('instrumentSelectorTitle').textContent = `Select Instrument for ${sectionNames[section] || section}`;
        renderSectionInstrumentSelectorContent(groupIndex, testCase, section);
        
        const modal = new bootstrap.Modal(document.getElementById('instrumentSelectorModal'));
        modal.show();
    }
    
    function renderSectionInstrumentSelectorContent(groupIndex, testCase, section) {
        const content = document.getElementById('instrumentSelectorContent');
        const group = campaign.testGroups[groupIndex];
        const groupSetupIds = group.setupIds || [];
        
        if (groupSetupIds.length === 0) {
            content.innerHTML = '<div class="alert alert-warning"><i class="bi bi-exclamation-triangle"></i> No setups assigned to this test group. Please assign setups first.</div>';
            return;
        }
        
        // Get current selection
        if (!testCase.sectionInstruments) testCase.sectionInstruments = {};
        const currentSelection = testCase.sectionInstruments[section] || {};
        
        // Get all instruments from assigned setups
        const setupInstruments = [];
        groupSetupIds.forEach(setupId => {
            const setup = allSetups.find(s => (s.id || s.Id) === setupId);
            if (setup) {
                const instrumentIds = setup.instrument_ids || setup.instrumentIds || setup.InstrumentIds || [];
                instrumentIds.forEach(instId => {
                    const instrument = allInstruments.find(i => (i.id || i.Id) === instId);
                    if (instrument) {
                        setupInstruments.push({
                            setupId: setup.id || setup.Id,
                            setupName: setup.name || setup.Name,
                            instrumentId: instrument.id || instrument.Id,
                            instrumentName: instrument.name || instrument.Name,
                            instrumentType: instrument.type || instrument.Type || 'General',
                            instrumentModel: instrument.model || instrument.Model || '',
                            isSelected: currentSelection.setupId === (setup.id || setup.Id) && currentSelection.instrumentId === (instrument.id || instrument.Id)
                        });
                    }
                });
            }
        });
        
        if (setupInstruments.length === 0) {
            content.innerHTML = '<div class="alert alert-info"><i class="bi bi-info-circle"></i> No instruments available in assigned setups.</div>';
            return;
        }
        
        // Group instruments by setup
        const instrumentsBySetup = {};
        setupInstruments.forEach(si => {
            if (!instrumentsBySetup[si.setupId]) {
                instrumentsBySetup[si.setupId] = {
                    setupName: si.setupName,
                    instruments: []
                };
            }
            instrumentsBySetup[si.setupId].instruments.push(si);
        });
        
        content.innerHTML = `
            <div style="margin-bottom:1.5rem;">
                <div style="background:linear-gradient(135deg,#faf5ff 0%,#f3e8ff 100%);border-radius:8px;padding:1rem;border:1px solid #d8b4fe;">
                    <div style="display:flex;align-items:center;gap:1rem;">
                        <i class="bi bi-info-circle-fill" style="color:#8b5cf6;font-size:1.5rem;"></i>
                        <div>
                            <h6 style="margin:0;color:#6b21a8;font-weight:700;">Section Instrument Assignment</h6>
                            <p style="margin:0;font-size:0.875rem;color:#7c3aed;">This instrument will be used for all operations in this section</p>
                        </div>
                    </div>
                </div>
            </div>
            
            ${Object.keys(instrumentsBySetup).map(setupId => {
                const setupData = instrumentsBySetup[setupId];
                return `
                    <div style="margin-bottom:1.5rem;">
                        <h6 style="color:#059669;font-weight:700;margin-bottom:1rem;display:flex;align-items:center;gap:0.5rem;">
                            <i class="bi bi-hdd-network-fill"></i>
                            ${setupData.setupName} (${setupData.instruments.length} Instrument${setupData.instruments.length > 1 ? 's' : ''})
                        </h6>
                        <div style="display:grid;gap:0.75rem;">
                            ${setupData.instruments.map(inst => renderInstrumentCard(inst)).join('')}
                        </div>
                    </div>
                `;
            }).join('')}
        `;
    }
    
    function selectInstrument(setupId, instrumentId) {
        if (!currentInstrumentContext) return;
        
        const { groupIndex, tcIndex, section } = currentInstrumentContext;
        const testCase = campaign.testGroups[groupIndex].testCaseExecutions[tcIndex];
        
        if (!testCase.sectionInstruments) testCase.sectionInstruments = {};
        testCase.sectionInstruments[section] = {
            setupId: setupId,
            instrumentId: instrumentId
        };
        
        const setup = allSetups.find(s => (s.id || s.Id) === setupId);
        const instrument = allInstruments.find(i => (i.id || i.Id) === instrumentId);
        
        renderTree();
        renderSectionInstrumentSelectorContent(groupIndex, testCase, section);
        showToast(`Assigned ${instrument?.name || instrument?.Name} from ${setup?.name || setup?.Name}`, 'success');
    }
    
    function renderInstrumentCard(inst) {
        const bgColor = inst.isSelected ? '#f0fdf4' : '#ffffff';
        const borderColor = inst.isSelected ? '#10b981' : '#e2e8f0';
        const borderWidth = inst.isSelected ? '3px' : '2px';
        const checkIcon = inst.isSelected ? '<i class="bi bi-check-circle-fill" style="color:#10b981;font-size:1.25rem;"></i>' : '';
        
        return `
            <div onclick="selectInstrument('${inst.setupId}', '${inst.instrumentId}')" style="background:${bgColor};border-radius:8px;padding:1rem;border:${borderWidth} solid ${borderColor};transition:all 0.2s;cursor:pointer;" onmouseover="if(!this.style.borderColor.includes('10b981')) this.style.borderColor='#a78bfa'; this.style.transform='translateY(-2px)';this.style.boxShadow='0 4px 12px rgba(0,0,0,0.1)';" onmouseout="if(!this.style.borderColor.includes('10b981')) this.style.borderColor='#e2e8f0'; this.style.transform='translateY(0)';this.style.boxShadow='none';">
                <div style="display:flex;gap:0.75rem;align-items:center;">
                    <div style="width:48px;height:48px;background:linear-gradient(135deg,#8b5cf6 0%,#7c3aed 100%);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                        <i class="bi bi-hdd-rack-fill" style="color:white;font-size:1.5rem;"></i>
                    </div>
                    <div style="flex:1;min-width:0;">
                        <h6 style="margin:0 0 0.25rem 0;font-weight:700;color:#0f172a;">${inst.instrumentName}</h6>
                        <div style="display:flex;gap:1rem;font-size:0.75rem;color:#64748b;">
                            <span><i class="bi bi-tag"></i> ${inst.instrumentType}</span>
                            ${inst.instrumentModel ? `<span><i class="bi bi-box"></i> ${inst.instrumentModel}</span>` : ''}
                        </div>
