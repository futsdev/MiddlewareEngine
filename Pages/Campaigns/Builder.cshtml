            renderOperationProperties(groupIndex, tcIndex, section, opIndex); // Refresh properties panel
        }
    }
    
    function moveTestCase(groupIndex, tcIndex, direction) {
        const testCases = campaign.testGroups[groupIndex].testCaseExecutions;
        const newIndex = tcIndex + direction;
        
        if (newIndex < 0 || newIndex >= testCases.length) return;
        
        // Swap
        [testCases[tcIndex], testCases[newIndex]] = [testCases[newIndex], testCases[tcIndex]];
        
        // Update orders
        testCases.forEach((tc, idx) => tc.order = idx);
        
        renderTree();
        showToast('Test case moved', 'success');
    }
    
    function moveOperation(groupIndex, tcIndex, section, opIndex, direction) {
        event.stopPropagation();
        
        const tc = campaign.testGroups[groupIndex].testCaseExecutions[tcIndex];
        const testCaseDetails = allTestCases.find(t => t.id === tc.functionId || t.id === tc.testCaseId);
        
        if (!testCaseDetails) return;
        
        // Navigate to the operations array
        let operations = null;
        
        if (section.startsWith('setup')) {
            operations = testCaseDetails.setupOperations || testCaseDetails.SetupOperations;
        } else if (section.startsWith('teardown')) {
            operations = testCaseDetails.teardownOperations || testCaseDetails.TeardownOperations;
        } else if (section.startsWith('precondition')) {
            const parts = section.split('-');
            const stepIdx = parseInt(parts[1]);
            const actionIdx = parseInt(parts[2]);
            const steps = testCaseDetails.steps || testCaseDetails.Steps;
            const actions = steps[stepIdx]?.actions || steps[stepIdx]?.Actions;
            operations = actions[actionIdx]?.preConditions || actions[actionIdx]?.PreConditions;
        } else if (section.startsWith('operation')) {
            const parts = section.split('-');
            const stepIdx = parseInt(parts[1]);
            const actionIdx = parseInt(parts[2]);
            const steps = testCaseDetails.steps || testCaseDetails.Steps;
            const actions = steps[stepIdx]?.actions || steps[stepIdx]?.Actions;
            operations = actions[actionIdx]?.operations || actions[actionIdx]?.Operations;
        } else if (section.startsWith('postcondition')) {
            const parts = section.split('-');
            const stepIdx = parseInt(parts[1]);
            const actionIdx = parseInt(parts[2]);
            const steps = testCaseDetails.steps || testCaseDetails.Steps;
            const actions = steps[stepIdx]?.actions || steps[stepIdx]?.Actions;
            operations = actions[actionIdx]?.postConditions || actions[actionIdx]?.PostConditions;
        }
        
        if (!operations || !Array.isArray(operations)) return;
        
        const newIndex = opIndex + direction;
        
        if (newIndex < 0 || newIndex >= operations.length) return;
        
        // Swap
        [operations[opIndex], operations[newIndex]] = [operations[newIndex], operations[opIndex]];
        
        renderTree();
        showToast('Operation moved', 'success');
    }

