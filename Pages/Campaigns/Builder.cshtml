    function renderTestCases(group, groupIndex) {
        if (!group.testCaseExecutions || group.testCaseExecutions.length === 0) {
            return '<div class="testcase-node">' +
                    '<div style="padding:1rem;text-align:center;color:#94a3b8;font-size:0.875rem;">' +
                        '<i class="bi bi-inbox"></i> Drag test cases here' +
                    '</div>' +
                '</div>';
        }

        return group.testCaseExecutions.map((tc, tcIndex) => {
            const testCaseDetails = allTestCases.find(t => t.id === tc.functionId || t.id === tc.testCaseId);
            const toggleClass = tc.collapsed ? 'collapsed' : '';
            const statusClass = tc.enabled ? 'status-enabled' : 'status-disabled';
            const toggleIcon = tc.enabled ? 'toggle-on' : 'toggle-off';
            const toggleDisabled = !tc.enabled ? 'disabled' : '';
            const displayStyle = tc.collapsed ? 'none' : 'block';
            
            // Check if this test case appears multiple times in the group
            const sameTestCaseCount = group.testCaseExecutions.filter(t => 
                (t.functionId === tc.functionId || t.testCaseId === tc.testCaseId)).length;
            const isDuplicate = sameTestCaseCount > 1;
            const instanceNum = group.testCaseExecutions.slice(0, tcIndex + 1).filter(t => 
                (t.functionId === tc.functionId || t.testCaseId === tc.testCaseId)).length;
            
            // Calculate total operations count
            const setupCount = (testCaseDetails?.setupOperations || testCaseDetails?.SetupOperations || []).length;
            const teardownCount = (testCaseDetails?.teardownOperations || testCaseDetails?.TeardownOperations || []).length;
            let stepsCount = 0;
            const steps = testCaseDetails?.steps || testCaseDetails?.Steps || [];
            steps.forEach(step => {
                const actions = step.actions || step.Actions || [];
                actions.forEach(action => {
                    stepsCount += (action.preConditions || action.PreConditions || []).length;
                    stepsCount += (action.operations || action.Operations || []).length;
                    stepsCount += (action.postConditions || action.PostConditions || []).length;
                });
            });
            const totalOps = setupCount + stepsCount + teardownCount;
            
            return '<div class="tree-node testcase-node" style="border-left:3px solid #3b82f6;">' +
                    '<div class="tree-node-content">' +
                        '<div class="testcase-header" style="background:linear-gradient(135deg,#eff6ff 0%,#dbeafe 100%);padding:0.75rem;border-radius:6px;">' +
                            '<div class="testcase-toggle ' + toggleClass + '" onclick="toggleTestCase(' + groupIndex + ', ' + tcIndex + ')">' +
                                '<i class="bi bi-chevron-down"></i>' +
                            '</div>' +
                            '<div class="testcase-icon" style="background:#3b82f6;color:white;font-weight:600;">' + (tcIndex + 1) + '</div>' +
                            '<div class="status-indicator ' + statusClass + '"></div>' +
                            '<div class="testcase-info" style="flex:1;">' +
                                '<div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.5rem;">' +
                                    '<h5 class="testcase-name" style="font-size:0.95rem;color:#1e40af;margin:0;">' + (tc.functionName || 'Test Case') + '</h5>' +
                                    (isDuplicate ? '<span style="background:linear-gradient(135deg,#fbbf24 0%,#f59e0b 100%);color:white;padding:0.25rem 0.5rem;border-radius:4px;font-size:0.65rem;font-weight:700;box-shadow:0 1px 3px rgba(251,191,36,0.3);">' +
                                        '<i class="bi bi-layers-fill"></i> Instance #' + instanceNum + ' of ' + sameTestCaseCount +
                                    '</span>' : '') +
                                '</div>' +
                                '<div class="testcase-function" style="font-size:0.75rem;color:#64748b;margin-bottom:0.5rem;">' +
                                    '<i class="bi bi-diagram-3"></i> ' + totalOps + ' operations • ' +
                                    '<i class="bi bi-gear"></i> ' + setupCount + ' setup • ' +
                                    '<i class="bi bi-play"></i> ' + steps.length + ' steps • ' +
                                    '<i class="bi bi-flag"></i> ' + teardownCount + ' teardown' +
                                '</div>' +
                                '<div class="testcase-inline-properties" style="display:flex;gap:0.75rem;flex-wrap:wrap;">' +
                                    '<div style="display:flex;align-items:center;gap:0.375rem;background:white;padding:0.25rem 0.5rem;border-radius:4px;border:1px solid #e2e8f0;">' +
                                        '<i class="bi bi-arrow-repeat" style="color:#f59e0b;font-size:0.75rem;"></i>' +
                                        '<label style="font-size:0.7rem;color:#64748b;margin:0;">Retry:</label>' +
                                        '<input type="number" min="0" max="10" value="' + (tc.retryCount || 0) + '" ' +
                                               'onchange="updateTestCaseRetry(' + groupIndex + ', ' + tcIndex + ', this.value)" ' +
                                               'onclick="event.stopPropagation()" ' +
                                               'style="width:50px;padding:0.125rem 0.25rem;border:1px solid #cbd5e1;border-radius:3px;font-size:0.75rem;text-align:center;" />' +
                                    '</div>' +
                                    '<div style="display:flex;align-items:center;gap:0.375rem;background:white;padding:0.25rem 0.5rem;border-radius:4px;border:1px solid #e2e8f0;">' +
                                        '<i class="bi bi-clock" style="color:#8b5cf6;font-size:0.75rem;"></i>' +
                                        '<label style="font-size:0.7rem;color:#64748b;margin:0;">Delay (s):</label>' +
                                        '<input type="number" min="0" max="3600" step="0.5" value="' + (tc.delaySeconds || 0) + '" ' +
                                               'onchange="updateTestCaseDelay(' + groupIndex + ', ' + tcIndex + ', this.value)" ' +
                                               'onclick="event.stopPropagation()" ' +
                                               'style="width:60px;padding:0.125rem 0.25rem;border:1px solid #cbd5e1;border-radius:3px;font-size:0.75rem;text-align:center;" />' +
                                    '</div>' +
                                    '<div style="display:flex;align-items:center;gap:0.375rem;background:white;padding:0.25rem 0.5rem;border-radius:4px;border:1px solid #e2e8f0;">' +
                                        '<i class="bi bi-exclamation-triangle" style="color:#ef4444;font-size:0.75rem;"></i>' +
                                        '<label style="font-size:0.7rem;color:#64748b;margin:0;cursor:pointer;" onclick="event.stopPropagation();">' +
                                            '<input type="checkbox" ' + (tc.abortOnFailure ? 'checked' : '') + ' ' +
                                                   'onchange="updateTestCaseAbort(' + groupIndex + ', ' + tcIndex + ', this.checked)" ' +
                                                   'onclick="event.stopPropagation()" ' +
                                                   'style="margin:0 0.25rem 0 0;cursor:pointer;" /> Abort on Fail' +
                                        '</label>' +
                                    '</div>' +
                                '</div>' +
                            '</div>' +
                            '<div class="testcase-controls">' +
                                '<button class="btn-icon" onclick="expandAllSections(' + groupIndex + ', ' + tcIndex + ')" title="Expand All" style="font-size:0.7rem;background:#10b981;color:white;">' +
                                    '<i class="bi bi-arrows-expand"></i>' +
                                '</button>' +
                                '<button class="btn-icon" onclick="collapseAllSections(' + groupIndex + ', ' + tcIndex + ')" title="Collapse All" style="font-size:0.7rem;background:#64748b;color:white;">' +
                                    '<i class="bi bi-arrows-collapse"></i>' +
                                '</button>' +
                                '<button class="btn-icon" onclick="moveTestCase(' + groupIndex + ', ' + tcIndex + ', -1)" title="Move Up" style="font-size:0.7rem;">' +
                                    '<i class="bi bi-arrow-up"></i>' +
                                '</button>' +
                                '<button class="btn-icon" onclick="moveTestCase(' + groupIndex + ', ' + tcIndex + ', 1)" title="Move Down" style="font-size:0.7rem;">' +
                                    '<i class="bi bi-arrow-down"></i>' +
                                '</button>' +
                                '<button class="btn-icon btn-toggle ' + toggleDisabled + '" onclick="toggleTestCaseEnabled(' + groupIndex + ', ' + tcIndex + ')" title="Enable/Disable">' +
                                    '<i class="bi bi-' + toggleIcon + '"></i>' +
                                '</button>' +
                                '<button class="btn-icon btn-edit" onclick="selectTestCase(' + groupIndex + ', ' + tcIndex + ')" title="Properties">' +
                                    '<i class="bi bi-gear"></i>' +
                                '</button>' +
                                '<button class="btn-icon btn-delete" onclick="deleteTestCase(' + groupIndex + ', ' + tcIndex + ')" title="Remove">' +
                                    '<i class="bi bi-x-circle"></i>' +
                                '</button>' +
                            '</div>' +
                        '</div>' +
                    '</div>' +
                    '<div class="testcase-functions" style="display: ' + displayStyle + ';padding-left:1rem;margin-top:0.5rem;">' +
                        renderTestCaseHierarchy(testCaseDetails, groupIndex, tcIndex) +
                    '</div>' +
                '</div>';
        }).join('');
    }
    
    function renderTestCaseHierarchy(testCase, groupIndex, tcIndex) {
        if (!testCase) return '<div style="padding:0.5rem;color:#ef4444;">Test case not found</div>';
        
        let html = '';
        const tc = campaign.testGroups[groupIndex].testCaseExecutions[tcIndex];
        
        // Initialize collapse states if not present
        if (!tc.collapseStates) {
            tc.collapseStates = {
                setup: false,
                teardown: false,
                postTestCleanup: false,
                steps: {},
                actions: {}
            };
        }
        
        // Setup Operations Section - ALWAYS SHOW
        const setupOps = testCase.setupOperations || testCase.SetupOperations || [];
        const isSetupCollapsed = tc.collapseStates.setup;
        const setupChevron = isSetupCollapsed ? 'bi-chevron-right' : 'bi-chevron-down';
        const setupDisplay = isSetupCollapsed ? 'none' : 'block';
        
        // Get instrument info for setup section
        if (!tc.sectionInstruments) tc.sectionInstruments = {};
        const setupInstrument = getSectionInstrumentInfo(groupIndex, tc, 'setup');
        
        html += '<div class="hierarchy-section" style="margin-bottom:0.75rem;background:#fef9e7;border-radius:8px;padding:0.5rem;border:1px solid #fef3c7;transition:all 0.3s;">' +
                '<div class="hierarchy-header" style="background:linear-gradient(135deg,#fef3c7 0%,#fde68a 100%);color:#92400e;padding:0.5rem 0.75rem;border-radius:6px;font-size:0.85rem;font-weight:600;display:flex;align-items:center;gap:0.5rem;box-shadow:0 1px 2px rgba(0,0,0,0.05);transition:all 0.2s;">' +
                    '<i class="bi ' + setupChevron + '" onclick="toggleHierarchySection(' + groupIndex + ', ' + tcIndex + ', \'setup\')" style="cursor:pointer;transition:transform 0.2s;font-size:0.9rem;"></i>' +
                    '<i class="bi bi-gear-fill"></i>' +
                    '<span onclick="toggleHierarchySection(' + groupIndex + ', ' + tcIndex + ', \'setup\')" style="cursor:pointer;flex:1;">Setup Operations</span>' +
                    '<button class="btn-icon" onclick="event.stopPropagation();openSectionInstrumentSelector(' + groupIndex + ', ' + tcIndex + ', \'setup\')" style="font-size:0.7rem;padding:0.3rem 0.5rem;background:linear-gradient(135deg,#8b5cf6 0%,#7c3aed 100%);color:white;border:none;border-radius:4px;" title="Select Instrument">' +
                        '<i class="bi bi-hdd-rack"></i>' +
                    '</button>' +
                    '<span style="background:#92400e;color:#fef3c7;padding:0.15rem 0.5rem;border-radius:12px;font-size:0.75rem;">' + setupOps.length + '</span>' +
                '</div>' +
                (setupInstrument.hasInstrument ? 
                    '<div style="display:flex;align-items:center;gap:0.5rem;padding:0.5rem 0.75rem;background:linear-gradient(135deg,#f0fdf4 0%,#dcfce7 100%);border-radius:4px;margin:0.5rem 0;border:1px solid #86efac;">' +
                        '<i class="bi bi-hdd-rack-fill" style="color:#16a34a;font-size:0.85rem;"></i>' +
                        '<div style="flex:1;font-size:0.75rem;">' +
                            '<span style="color:#166534;font-weight:600;">' + setupInstrument.instrumentName + '</span>' +
                            '<span style="color:#4ade80;margin:0 0.375rem;">•</span>' +
                            '<span style="color:#15803d;font-size:0.7rem;">' + setupInstrument.setupName + '</span>' +
                        '</div>' +
                        '<button class="btn-icon" onclick="event.stopPropagation();openSectionInstrumentSelector(' + groupIndex + ', ' + tcIndex + ', \'setup\')" style="font-size:0.65rem;padding:0.2rem 0.4rem;background:#10b981;color:white;border:none;border-radius:4px;" title="Change Instrument">' +
                            '<i class="bi bi-arrow-repeat"></i>' +
                        '</button>' +
                    '</div>' : '') +
                '<div class="hierarchy-operations" style="padding:0.5rem 0.5rem 0 1rem;display:' + setupDisplay + ';animation:slideDown 0.3s ease-out;">' +
                    (setupOps.length > 0 ? 
                        setupOps.map((op, idx) => renderOperation(op, groupIndex, tcIndex, 'setup', idx)).join('') : 
                        '<div style="padding:0.75rem;text-align:center;color:#92400e;background:#fef3c7;border-radius:4px;font-size:0.75rem;">No setup operations configured</div>') +
                    '<button onclick="addOperation(' + groupIndex + ', ' + tcIndex + ', \'setup\')" ' +
                        'style="width:100%;margin-top:0.5rem;padding:0.5rem;background:white;border:2px dashed #fde68a;border-radius:6px;color:#92400e;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:0.5rem;font-size:0.75rem;transition:all 0.2s;" ' +
                        'onmouseover="this.style.background=\'#fef3c7\';this.style.borderColor=\'#92400e\';" ' +
                        'onmouseout="this.style.background=\'white\';this.style.borderColor=\'#fde68a\';">' +
                        '<i class="bi bi-plus-circle"></i> Add Setup Operation' +
                    '</button>' +
                '</div>' +
            '</div>';
        
        // Steps Section
        const steps = testCase.steps || testCase.Steps || [];
        if (steps.length > 0) {
            steps.forEach((step, stepIdx) => {
                const actions = step.actions || step.Actions || [];
                const stepKey = 'step-' + stepIdx;
                const isStepCollapsed = tc.collapseStates.steps[stepKey];
                const stepChevron = isStepCollapsed ? 'bi-chevron-right' : 'bi-chevron-down';
                const stepDisplay = isStepCollapsed ? 'none' : 'block';
                const stepInstrument = getSectionInstrumentInfo(groupIndex, tc, stepKey);
                
                html += '<div class="hierarchy-section" style="margin-bottom:0.75rem;background:linear-gradient(to right,#eff6ff 0%,#ffffff 100%);border-radius:8px;padding:0.5rem;border:1px solid #bfdbfe;border-left:3px solid #3b82f6;transition:all 0.3s;">' +
                        '<div class="hierarchy-header" style="background:linear-gradient(135deg,#dbeafe 0%,#bfdbfe 100%);color:#1e40af;padding:0.5rem 0.75rem;border-radius:6px;font-size:0.85rem;font-weight:600;display:flex;align-items:center;gap:0.5rem;box-shadow:0 1px 2px rgba(0,0,0,0.05);transition:all 0.2s;">' +
                            '<i class="bi ' + stepChevron + '" onclick="toggleHierarchySection(' + groupIndex + ', ' + tcIndex + ', \'step\', ' + stepIdx + ')" style="cursor:pointer;transition:transform 0.2s;font-size:0.9rem;"></i>' +
                            '<i class="bi bi-list-ol"></i>' +
                            '<span onclick="toggleHierarchySection(' + groupIndex + ', ' + tcIndex + ', \'step\', ' + stepIdx + ')" style="cursor:pointer;flex:1;">Step ' + (stepIdx + 1) + '</span>' +
                            '<button class="btn-icon" onclick="event.stopPropagation();openSectionInstrumentSelector(' + groupIndex + ', ' + tcIndex + ', \'step-' + stepIdx + '\')" style="font-size:0.7rem;padding:0.3rem 0.5rem;background:linear-gradient(135deg,#8b5cf6 0%,#7c3aed 100%);color:white;border:none;border-radius:4px;" title="Select Instrument">' +
                                '<i class="bi bi-hdd-rack"></i>' +
                            '</button>' +
                            '<span style="background:#1e40af;color:#dbeafe;padding:0.15rem 0.5rem;border-radius:12px;font-size:0.75rem;">' + actions.length + ' actions</span>' +
                        '</div>' +
                        (stepInstrument.hasInstrument ? 
                            '<div style="display:flex;align-items:center;gap:0.5rem;padding:0.5rem 0.75rem;background:linear-gradient(135deg,#f0fdf4 0%,#dcfce7 100%);border-radius:4px;margin:0.5rem 0;border:1px solid #86efac;">' +
                                '<i class="bi bi-hdd-rack-fill" style="color:#16a34a;font-size:0.85rem;"></i>' +
                                '<div style="flex:1;font-size:0.75rem;">' +
                                    '<span style="color:#166534;font-weight:600;">' + stepInstrument.instrumentName + '</span>' +
                                    '<span style="color:#4ade80;margin:0 0.375rem;">•</span>' +
                                    '<span style="color:#15803d;font-size:0.7rem;">' + stepInstrument.setupName + '</span>' +
                                '</div>' +
                                '<button class="btn-icon" onclick="event.stopPropagation();openSectionInstrumentSelector(' + groupIndex + ', ' + tcIndex + ', \'step-' + stepIdx + '\')" style="font-size:0.65rem;padding:0.2rem 0.4rem;background:#10b981;color:white;border:none;border-radius:4px;" title="Change Instrument">' +
                                    '<i class="bi bi-arrow-repeat"></i>' +
                                '</button>' +
                            '</div>' : '') +
                        '<div style="padding:0.5rem 0 0 0.5rem;display:' + stepDisplay + ';animation:slideDown 0.3s ease-out;">';
                
                actions.forEach((action, actionIdx) => {
                    const actionKey = 'action-' + stepIdx + '-' + actionIdx;
                    const isActionCollapsed = tc.collapseStates.actions[actionKey];
                    const actionChevron = isActionCollapsed ? 'bi-chevron-right' : 'bi-chevron-down';
                    const actionDisplay = isActionCollapsed ? 'none' : 'block';
                    
                    const preConditions = action.preConditions || action.PreConditions || [];
                    const operations = action.operations || action.Operations || [];
                    const postConditions = action.postConditions || action.PostConditions || [];
                    const totalOps = preConditions.length + operations.length + postConditions.length;
                    
                    html += '<div class="hierarchy-action" style="margin-bottom:0.5rem;background:white;border-radius:6px;padding:0.4rem;border:1px solid #e0e7ff;transition:all 0.3s;">' +
                            '<div onclick="toggleHierarchySection(' + groupIndex + ', ' + tcIndex + ', \'action\', ' + stepIdx + ', ' + actionIdx + ')" ' +
                                 'style="font-size:0.8rem;color:#475569;font-weight:600;padding:0.3rem 0.5rem;border-radius:4px;background:#f8fafc;cursor:pointer;display:flex;align-items:center;gap:0.5rem;transition:all 0.2s;" ' +
                                 'onmouseover="this.style.background=\'#f1f5f9\';" ' +
                                 'onmouseout="this.style.background=\'#f8fafc\';">' +
                                '<i class="bi ' + actionChevron + '" style="transition:transform 0.2s;font-size:0.8rem;"></i>' +
                                '<i class="bi bi-play-circle-fill" style="color:#3b82f6;"></i>' +
                                '<span>Action ' + (actionIdx + 1) + '</span>' +
                                '<span style="background:#64748b;color:white;padding:0.1rem 0.4rem;border-radius:10px;font-size:0.7rem;margin-left:auto;">' + totalOps + ' ops</span>' +
                            '</div>' +
                            '<div style="padding:0.5rem 0 0 1rem;display:' + actionDisplay + ';animation:slideDown 0.3s ease-out;">';
                    
                    // PreConditions - ALWAYS SHOW
                    const preKey = 'pre-' + stepIdx + '-' + actionIdx;
                    const isPreCollapsed = tc.collapseStates.actions[preKey];
                    const preChevron = isPreCollapsed ? 'bi-chevron-right' : 'bi-chevron-down';
                    const preDisplay = isPreCollapsed ? 'none' : 'block';
                    
                    html += '<div style="margin-bottom:0.4rem;border-left:2px solid #6366f1;padding-left:0.5rem;">' +
                            '<div onclick="toggleHierarchySection(' + groupIndex + ', ' + tcIndex + ', \'pre\', ' + stepIdx + ', ' + actionIdx + ')" ' +
                                 'style="font-size:0.75rem;color:#6366f1;font-weight:600;margin-bottom:0.3rem;cursor:pointer;display:flex;align-items:center;gap:0.3rem;padding:0.2rem 0.4rem;border-radius:3px;transition:all 0.2s;" ' +
                                 'onmouseover="this.style.background=\'#f5f5ff\';" ' +
                                 'onmouseout="this.style.background=\'transparent\';">' +
                                '<i class="bi ' + preChevron + '" style="font-size:0.7rem;"></i>' +
                                '<i class="bi bi-check2-square"></i>' +
                                '<span>PreConditions (' + preConditions.length + ')</span>' +
                            '</div>' +
                            '<div style="padding-left:0.5rem;display:' + preDisplay + ';animation:slideDown 0.2s ease-out;">' +
                                (preConditions.length > 0 ? 
                                    preConditions.map((op, idx) => renderOperation(op, groupIndex, tcIndex, 'precondition-' + stepIdx + '-' + actionIdx, idx)).join('') :
                                    '<div style="padding:0.5rem;text-align:center;color:#6366f1;background:#f5f5ff;border-radius:4px;font-size:0.7rem;">No pre-conditions</div>') +
                                '<button onclick="addOperation(' + groupIndex + ', ' + tcIndex + ', \'precondition-' + stepIdx + '-' + actionIdx + '\')" ' +
                                    'style="width:100%;margin-top:0.3rem;padding:0.4rem;background:white;border:1px dashed #c7d2fe;border-radius:4px;color:#6366f1;font-weight:600;cursor:pointer;font-size:0.7rem;" ' +
                                    'onmouseover="this.style.background=\'#f5f5ff\';" onmouseout="this.style.background=\'white\';">' +
                                    '<i class="bi bi-plus-circle"></i> Add PreCondition' +
                                '</button>' +
                            '</div>' +
                        '</div>';
                    
                    // Operations - ALWAYS SHOW
                    const opKey = 'ops-' + stepIdx + '-' + actionIdx;
                    const isOpsCollapsed = tc.collapseStates.actions[opKey];
                    const opsChevron = isOpsCollapsed ? 'bi-chevron-right' : 'bi-chevron-down';
                    const opsDisplay = isOpsCollapsed ? 'none' : 'block';
                    
                    html += '<div style="margin-bottom:0.4rem;border-left:2px solid #10b981;padding-left:0.5rem;">' +
                            '<div onclick="toggleHierarchySection(' + groupIndex + ', ' + tcIndex + ', \'ops\', ' + stepIdx + ', ' + actionIdx + ')" ' +
                                 'style="font-size:0.75rem;color:#10b981;font-weight:600;margin-bottom:0.3rem;cursor:pointer;display:flex;align-items:center;gap:0.3rem;padding:0.2rem 0.4rem;border-radius:3px;transition:all 0.2s;" ' +
                                 'onmouseover="this.style.background=\'#f0fdf4\';" ' +
                                 'onmouseout="this.style.background=\'transparent\';">' +
                                '<i class="bi ' + opsChevron + '" style="font-size:0.7rem;"></i>' +
                                '<i class="bi bi-play-fill"></i>' +
                                '<span>Operations (' + operations.length + ')</span>' +
                            '</div>' +
                            '<div style="padding-left:0.5rem;display:' + opsDisplay + ';animation:slideDown 0.2s ease-out;">' +
                                (operations.length > 0 ? 
                                    operations.map((op, idx) => renderOperation(op, groupIndex, tcIndex, 'operation-' + stepIdx + '-' + actionIdx, idx)).join('') :
                                    '<div style="padding:0.5rem;text-align:center;color:#10b981;background:#f0fdf4;border-radius:4px;font-size:0.7rem;">No operations</div>') +
                                '<button onclick="addOperation(' + groupIndex + ', ' + tcIndex + ', \'operation-' + stepIdx + '-' + actionIdx + '\')" ' +
                                    'style="width:100%;margin-top:0.3rem;padding:0.4rem;background:white;border:1px dashed #a7f3d0;border-radius:4px;color:#10b981;font-weight:600;cursor:pointer;font-size:0.7rem;" ' +
                                    'onmouseover="this.style.background=\'#f0fdf4\';" onmouseout="this.style.background=\'white\';">' +
                                    '<i class="bi bi-plus-circle"></i> Add Operation' +
                                '</button>' +
                            '</div>' +
                        '</div>';
                    
                    // PostConditions - ALWAYS SHOW
                    const postKey = 'post-' + stepIdx + '-' + actionIdx;
                    const isPostCollapsed = tc.collapseStates.actions[postKey];
                    const postChevron = isPostCollapsed ? 'bi-chevron-right' : 'bi-chevron-down';
                    const postDisplay = isPostCollapsed ? 'none' : 'block';
                    
                    html += '<div style="margin-bottom:0.4rem;border-left:2px solid #a855f7;padding-left:0.5rem;">' +
                            '<div onclick="toggleHierarchySection(' + groupIndex + ', ' + tcIndex + ', \'post\', ' + stepIdx + ', ' + actionIdx + ')" ' +
                                 'style="font-size:0.75rem;color:#a855f7;font-weight:600;margin-bottom:0.3rem;cursor:pointer;display:flex;align-items:center;gap:0.3rem;padding:0.2rem 0.4rem;border-radius:3px;transition:all 0.2s;" ' +
                                 'onmouseover="this.style.background=\'#faf5ff\';" ' +
                                 'onmouseout="this.style.background=\'transparent\';">' +
                                '<i class="bi ' + postChevron + '" style="font-size:0.7rem;"></i>' +
                                '<i class="bi bi-check-circle"></i>' +
                                '<span>PostConditions (' + postConditions.length + ')</span>' +
                            '</div>' +
                            '<div style="padding-left:0.5rem;display:' + postDisplay + ';animation:slideDown 0.2s ease-out;">' +
                                (postConditions.length > 0 ? 
                                    postConditions.map((op, idx) => renderOperation(op, groupIndex, tcIndex, 'postcondition-' + stepIdx + '-' + actionIdx, idx)).join('') :
                                    '<div style="padding:0.5rem;text-align:center;color:#a855f7;background:#faf5ff;border-radius:4px;font-size:0.7rem;">No post-conditions</div>') +
                                '<button onclick="addOperation(' + groupIndex + ', ' + tcIndex + ', \'postcondition-' + stepIdx + '-' + actionIdx + '\')" ' +
                                    'style="width:100%;margin-top:0.3rem;padding:0.4rem;background:white;border:1px dashed #e9d5ff;border-radius:4px;color:#a855f7;font-weight:600;cursor:pointer;font-size:0.7rem;" ' +
                                    'onmouseover="this.style.background=\'#faf5ff\';" onmouseout="this.style.background=\'white\';">' +
                                    '<i class="bi bi-plus-circle"></i> Add PostCondition' +
                                '</button>' +
                            '</div>' +
                        '</div>';
                    
                    html += '</div></div>';
                });
                
                html += '</div></div>';
            });
        }
        
        // Teardown Operations Section - ALWAYS SHOW
        const testCaseDef = tc.testCaseDefinition || tc.TestCaseDefinition || tc.test_case_definition;
        const teardownOps = testCaseDef?.Teardown?.Operations || testCaseDef?.teardown?.operations ||
                          testCaseDef?.TeardownOperations || testCaseDef?.teardownOperations ||
                          testCase.teardownOperations || testCase.TeardownOperations || [];
        const isTeardownCollapsed = tc.collapseStates.teardown;
        const teardownChevron = isTeardownCollapsed ? 'bi-chevron-right' : 'bi-chevron-down';
        const teardownDisplay = isTeardownCollapsed ? 'none' : 'block';
        const teardownInstrument = getSectionInstrumentInfo(groupIndex, tc, 'teardown');
        
        html += '<div class="hierarchy-section" style="margin-bottom:0.75rem;background:#fff5f5;border-radius:8px;padding:0.5rem;border:1px solid #fecaca;transition:all 0.3s;">' +
                '<div class="hierarchy-header" style="background:linear-gradient(135deg,#fecaca 0%,#fca5a5 100%);color:#991b1b;padding:0.5rem 0.75rem;border-radius:6px;font-size:0.85rem;font-weight:600;display:flex;align-items:center;gap:0.5rem;box-shadow:0 1px 2px rgba(0,0,0,0.05);transition:all 0.2s;">' +
                    '<i class="bi ' + teardownChevron + '" onclick="toggleHierarchySection(' + groupIndex + ', ' + tcIndex + ', \'teardown\')" style="cursor:pointer;transition:transform 0.2s;font-size:0.9rem;"></i>' +
                    '<i class="bi bi-flag-fill"></i>' +
                    '<span onclick="toggleHierarchySection(' + groupIndex + ', ' + tcIndex + ', \'teardown\')" style="cursor:pointer;flex:1;">Teardown Operations</span>' +
