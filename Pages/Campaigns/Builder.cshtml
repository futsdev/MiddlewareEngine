        html += '<div class="hierarchy-section" style="margin-bottom:0.75rem;background:#f5f3ff;border-radius:8px;padding:0.5rem;border:1px solid #e9d5ff;transition:all 0.3s;">' +
                '<div class="hierarchy-header" style="background:linear-gradient(135deg,#e9d5ff 0%,#d8b4fe 100%);color:#6b21a8;padding:0.5rem 0.75rem;border-radius:6px;font-size:0.85rem;font-weight:600;display:flex;align-items:center;gap:0.5rem;box-shadow:0 1px 2px rgba(0,0,0,0.05);transition:all 0.2s;">' +
                    '<i class="bi ' + cleanupChevron + '" onclick="toggleHierarchySection(' + groupIndex + ', ' + tcIndex + ', \'postTestCleanup\')" style="cursor:pointer;transition:transform 0.2s;font-size:0.9rem;"></i>' +
                    '<i class="bi bi-trash3-fill"></i>' +
                    '<span onclick="toggleHierarchySection(' + groupIndex + ', ' + tcIndex + ', \'postTestCleanup\')" style="cursor:pointer;flex:1;">Post-Test Cleanup</span>' +
                    '<button class="btn-icon" onclick="event.stopPropagation();openSectionInstrumentSelector(' + groupIndex + ', ' + tcIndex + ', \'cleanup\')" style="font-size:0.7rem;padding:0.3rem 0.5rem;background:linear-gradient(135deg,#8b5cf6 0%,#7c3aed 100%);color:white;border:none;border-radius:4px;" title="Select Instrument">' +
