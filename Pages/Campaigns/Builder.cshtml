    function selectFunctionForAdd(groupIndex, tcIndex, functionId) {
        const func = allFunctions.find(f => f.id === functionId);
        
        if (!campaign.testGroups[groupIndex].testCaseExecutions[tcIndex].functions) {
            campaign.testGroups[groupIndex].testCaseExecutions[tcIndex].functions = [];
        }
        
        const functions = campaign.testGroups[groupIndex].testCaseExecutions[tcIndex].functions;
        
        const newFunc = {
            id: Date.now().toString(),
            functionId: func.id,
            functionName: func.name,
            order: functions.length,
            parameterOverrides: {},
            enabled: true
        };
        
        functions.push(newFunc);
        closeFunctionSelector();
        renderTree();
        showToast(`Added function "${func.name}"`, 'success');
