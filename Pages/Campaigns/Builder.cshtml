    function validateInstrumentAssignments() {
        const missing = [];
        
        if (!campaign.testGroups) return missing;
        
        campaign.testGroups.forEach((group, groupIndex) => {
            if (!group.testCaseExecutions) return;
            
            group.testCaseExecutions.forEach((tc, tcIndex) => {
                const testCaseDetails = allTestCases.find(t => t.id === tc.functionId || t.id === tc.testCaseId);
                if (!testCaseDetails) return;
                
                const groupName = group.name || `Test Group ${groupIndex + 1}`;
                const testCaseName = tc.functionName || 'Test Case';
                
                // Initialize sectionInstruments if not present
                if (!tc.sectionInstruments) tc.sectionInstruments = {};
                
                // Check Setup Operations
                const setupOps = testCaseDetails.setupOperations || testCaseDetails.SetupOperations || [];
                if (setupOps.length > 0 && !tc.sectionInstruments.setup) {
                    missing.push({
                        groupName: groupName,
                        testCaseName: testCaseName,
                        sectionName: 'Setup Operations',
                        groupIndex: groupIndex,
                        tcIndex: tcIndex
                    });
                }
                
                // Check Steps
                const steps = testCaseDetails.steps || testCaseDetails.Steps || [];
                steps.forEach((step, stepIdx) => {
                    const stepKey = 'step-' + stepIdx;
                    const actions = step.actions || step.Actions || [];
                    if (actions.length > 0 && !tc.sectionInstruments[stepKey]) {
                        missing.push({
                            groupName: groupName,
                            testCaseName: testCaseName,
                            sectionName: `Step ${stepIdx + 1}`,
                            groupIndex: groupIndex,
                            tcIndex: tcIndex
                        });
                    }
                });
                
                // Check Teardown Operations
                const teardownOps = testCaseDetails.teardownOperations || testCaseDetails.TeardownOperations || [];
                if (teardownOps.length > 0 && !tc.sectionInstruments.teardown) {
                    missing.push({
                        groupName: groupName,
                        testCaseName: testCaseName,
                        sectionName: 'Teardown Operations',
                        groupIndex: groupIndex,
                        tcIndex: tcIndex
                    });
                }
                
                // Check Post-Test Cleanup
                const cleanupOps = testCaseDetails.postTestCleanup || testCaseDetails.PostTestCleanup || [];
                if (cleanupOps.length > 0 && !tc.sectionInstruments.cleanup) {
                    missing.push({
                        groupName: groupName,
                        testCaseName: testCaseName,
                        sectionName: 'Post-Test Cleanup',
                        groupIndex: groupIndex,
                        tcIndex: tcIndex
                    });
                }
            });
        });
        
        return missing;
    }

