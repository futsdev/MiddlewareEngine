    function renderLibrary() {
        const container = document.getElementById('libraryList');
        if (allTestCases.length === 0) {
            container.innerHTML = '<div class="empty-state"><i class="bi bi-inbox"></i><p>No test cases available</p></div>';
            return;
        }

        container.innerHTML = allTestCases.map(tc => {
            const func = allFunctions.find(f => f.id === tc.functionId);
            const paramCount = func?.parameters?.length || 0;
            const paramBadge = paramCount > 0 ? '<span style="background:#dbeafe;color:#1e40af;padding:0.125rem 0.375rem;border-radius:4px;font-size:0.75rem;margin-left:0.5rem;">' + paramCount + ' params</span>' : '';
            return '<div class="test-case-item" draggable="true" data-testcase-id="' + tc.id + '">' +
                '<div class="test-case-name">' + tc.name + paramBadge + '</div>' +
                '<div class="test-case-meta">' +
                    '<span><i class="bi bi-gear"></i> ' + (func?.name || 'Unknown') + '</span>' +
                    '<span><i class="bi bi-layers"></i> ' + (tc.steps?.length || 0) + ' steps</span>' +
                '</div>' +
            '</div>';
        }).join('');
    }

    function filterLibrary() {
        const search = document.getElementById('librarySearch').value.toLowerCase();
        const items = document.querySelectorAll('.test-case-item');
        items.forEach(item => {
            const text = item.textContent.toLowerCase();
            item.style.display = text.includes(search) ? 'block' : 'none';
        });
    }

    function setupDragAndDrop() {
        document.addEventListener('dragstart', function(e) {
            if (e.target.classList.contains('test-case-item')) {
                e.target.classList.add('dragging');
                draggedTestCase = e.target.dataset.testcaseId;
            }
        });

        document.addEventListener('dragend', function(e) {
            if (e.target.classList.contains('test-case-item')) {
                e.target.classList.remove('dragging');
                draggedTestCase = null;
            }
        });
    }

