    async function addSetupToCampaign(setupId) {
        try {
            const campaignSetupIds = campaign.setup_ids || campaign.setupIds || campaign.SetupIds || [];
            
            if (!campaignSetupIds.includes(setupId)) {
                campaignSetupIds.push(setupId);
            }
            
            campaign.setup_ids = campaignSetupIds;
            campaign.setupIds = campaignSetupIds;
            campaign.SetupIds = campaignSetupIds;
            
            // Also set the single setupId for backward compatibility (use first setup)
            campaign.setup_id = campaignSetupIds[0];
            campaign.setupId = campaignSetupIds[0];
            campaign.SetupId = campaignSetupIds[0];
            
            // Save to database
            const response = await fetch(`/api/campaigns/${campaignId}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(campaign)
            });
            
            if (!response.ok) {
                throw new Error('Failed to save campaign');
            }
            
            renderSetupDrawerContent();
            showToast('Setup assigned successfully!', 'success');
        } catch (error) {
            console.error('Error assigning setup:', error);
            showToast('Failed to assign setup', 'error');
        }
    }
    
    async function removeSetupFromCampaign(setupId) {
        if (!confirm('Are you sure you want to remove this setup from the campaign?')) {
            return;
        }
        
        try {
            const campaignSetupIds = campaign.setup_ids || campaign.setupIds || campaign.SetupIds || [];
            const index = campaignSetupIds.indexOf(setupId);
            
            if (index > -1) {
                campaignSetupIds.splice(index, 1);
            }
            
            campaign.setup_ids = campaignSetupIds;
            campaign.setupIds = campaignSetupIds;
            campaign.SetupIds = campaignSetupIds;
            
            // Update single setupId (use first setup or null)
            campaign.setup_id = campaignSetupIds.length > 0 ? campaignSetupIds[0] : null;
            campaign.setupId = campaignSetupIds.length > 0 ? campaignSetupIds[0] : null;
            campaign.SetupId = campaignSetupIds.length > 0 ? campaignSetupIds[0] : null;
            
            // Save to database
            const response = await fetch(`/api/campaigns/${campaignId}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(campaign)
            });
            
            if (!response.ok) {
                throw new Error('Failed to save campaign');
            }
            
            renderSetupDrawerContent();
            showToast('Setup removed successfully!', 'success');
        } catch (error) {
            console.error('Error removing setup:', error);
            showToast('Failed to remove setup', 'error');
        }
    }
    
    function updateCampaignHeader() {
        document.getElementById('campaignTitle').textContent = campaign.name || campaign.Name;
        const campaignProjectId = campaign.project_id || campaign.projectId || campaign.ProjectId;
        const project = allProjects.find(p => (p.id || p.Id) === campaignProjectId);
        document.getElementById('campaignProject').textContent = project?.name || project?.Name || 'Unknown Project';
        document.getElementById('campaignStatus').textContent = campaign.status || campaign.Status;
