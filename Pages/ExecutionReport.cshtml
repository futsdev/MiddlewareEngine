@page
@model MiddlewareEngine.Pages.ExecutionReportModel
@{
    ViewData["Title"] = "Execution Report";
}

<nav aria-label="breadcrumb" style="margin-bottom:1.5rem;">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/"><i class="bi bi-house-door"></i> Home</a></li>
        <li class="breadcrumb-item"><a href="/TestCases"><i class="fas fa-vial"></i> Test Cases</a></li>
        <li class="breadcrumb-item active" aria-current="page"><i class="fas fa-chart-bar"></i> Report</li>
    </ol>
</nav>

<!DOCTYPE html>
<html>
<head>
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #f8fafc;
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
        }

        .header {
            background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
            color: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(59, 130, 246, 0.2);
            margin-bottom: 30px;
        }

        .header h1 {
            color: white;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: #3b82f6;
            text-decoration: none;
            padding: 10px 20px;
            border: 2px solid #3b82f6;
            border-radius: 8px;
            margin-bottom: 20px;
            transition: all 0.3s;
        }

        .back-link:hover {
            background: #3b82f6;
            color: white;
        }

        .execution-summary {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            margin-bottom: 30px;
        }

        .summary-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }

        .summary-card {
            padding: 20px;
            border-radius: 10px;
            border-left: 5px solid;
        }

        .summary-card.success {
            background: #d1fae5;
            border-color: #10b981;
        }

        .summary-card.failed {
            background: #fee2e2;
            border-color: #ef4444;
        }

        .summary-card.running {
            background: #fef3c7;
            border-color: #f59e0b;
        }

        .summary-card h3 {
            font-size: 14px;
            color: #64748b;
            margin-bottom: 10px;
        }

        .summary-card .value {
            font-size: 32px;
            font-weight: bold;
            color: #0f172a;
        }

        .execution-timeline {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

        .timeline-section {
            margin-bottom: 30px;
        }

        .section-title {
            font-size: 20px;
            font-weight: bold;
            color: #3b82f6;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .step-container {
            border-left: 3px solid #ddd;
            padding-left: 30px;
            position: relative;
        }

        .step-item {
            margin-bottom: 25px;
            position: relative;
        }

        .step-item::before {
            content: '';
            position: absolute;
            left: -36px;
            top: 5px;
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: white;
            border: 3px solid;
        }

        .step-item.success::before {
            border-color: #10b981;
        }

        .step-item.failed::before {
            border-color: #ef4444;
        }

        .step-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 15px;
            background: #f8f9fa;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s;
        }

        .step-header:hover {
            background: #e9ecef;
        }

        .step-header .left {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .step-name {
            font-weight: bold;
            color: #333;
        }

        .status-badge {
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: bold;
        }

        .status-badge.success {
            background: #10b981;
            color: white;
        }

        .status-badge.failed {
            background: #ef4444;
            color: white;
        }

        .time-badge {
            background: #6c757d;
            color: white;
            padding: 5px 10px;
            border-radius: 5px;
            font-size: 12px;
        }

        .action-container {
            margin-top: 15px;
            padding-left: 20px;
            border-left: 2px dashed #ddd;
        }

        .action-item {
            margin-bottom: 15px;
            padding: 10px;
            background: white;
            border-radius: 5px;
            border: 1px solid #e0e0e0;
        }

        .action-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }

        .action-name {
            font-weight: 600;
            color: #555;
        }

        .operations-list {
            margin-top: 10px;
            padding-left: 15px;
        }

        .operation-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 8px;
            margin-bottom: 5px;
            background: #f8f9fa;
            border-radius: 4px;
            font-size: 14px;
        }

        .operation-name {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .operation-name i {
            width: 20px;
        }

        .icon-success {
            color: #10b981;
        }

        .icon-failed {
            color: #ef4444;
        }

        .error-message {
            background: #fee2e2;
            border: 1px solid #fecaca;
            color: #991b1b;
            padding: 10px;
            border-radius: 5px;
            margin-top: 10px;
            font-size: 13px;
        }

        .collapsible-content {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s ease;
        }

        .collapsible-content.open {
            max-height: 2000px;
        }

        .loading {
            text-align: center;
            padding: 50px;
            color: #3b82f6;
            font-size: 18px;
        }

        .no-data {
            text-align: center;
            padding: 50px;
            color: #999;
        }
    </style>
</head>
<body>
    <div class="container">
        <a href="/TestCases" class="back-link">
            <i class="fas fa-arrow-left"></i>
            Back to Test Cases
        </a>

        <div class="header">
            <h1>
                <i class="fas fa-chart-line"></i>
                <span id="testCaseName">Execution Report</span>
            </h1>
            <p id="testCaseDescription"></p>
        </div>

        <div id="loadingIndicator" class="loading">
            <i class="fas fa-spinner fa-spin"></i> Loading execution report...
        </div>

        <div id="reportContent" style="display: none;">
            <!-- Summary -->
            <div class="execution-summary">
                <h2>Execution Summary</h2>
                <div class="summary-grid">
                    <div class="summary-card" id="statusCard">
                        <h3>Status</h3>
                        <div class="value" id="statusValue">-</div>
                    </div>
                    <div class="summary-card">
                        <h3>Total Duration</h3>
                        <div class="value" id="durationValue">-</div>
                    </div>
                    <div class="summary-card">
                        <h3>Steps Executed</h3>
                        <div class="value" id="stepsValue">-</div>
                    </div>
                    <div class="summary-card">
                        <h3>Success Rate</h3>
                        <div class="value" id="successRate">-</div>
                    </div>
                </div>
            </div>

            <!-- Timeline -->
            <div class="execution-timeline">
                <h2>Execution Timeline</h2>

                <!-- Setup Operations -->
                <div class="timeline-section" id="setupSection">
                    <div class="section-title">
                        <i class="fas fa-cog"></i>
                        Setup Operations
                    </div>
                    <div id="setupOperations" class="step-container"></div>
                </div>

                <!-- Test Steps -->
                <div class="timeline-section" id="stepsSection">
                    <div class="section-title">
                        <i class="fas fa-list-ol"></i>
                        Test Steps
                    </div>
                    <div id="testSteps" class="step-container"></div>
                </div>

                <!-- Teardown Operations -->
                <div class="timeline-section" id="teardownSection">
                    <div class="section-title">
                        <i class="fas fa-power-off"></i>
                        Teardown Operations
                    </div>
                    <div id="teardownOperations" class="step-container"></div>
                </div>
            </div>
        </div>

        <div id="noData" class="no-data" style="display: none;">
            <i class="fas fa-exclamation-circle" style="font-size: 48px; margin-bottom: 20px;"></i>
            <h3>No execution data found</h3>
            <p>This execution report could not be loaded.</p>
        </div>
    </div>

    <script>
        const urlParams = new URLSearchParams(window.location.search);
        const executionId = urlParams.get('id');

        if (!executionId) {
            showNoData();
        } else {
            loadExecutionReport(executionId);
        }

        async function loadExecutionReport(executionId) {
            try {
                const response = await fetch(`/api/testexecution/execution/${executionId}`);
                if (!response.ok) throw new Error('Failed to load execution');

                const execution = await response.json();
                displayExecutionReport(execution);
            } catch (error) {
                console.error('Error loading execution:', error);
                showNoData();
            }
        }

        function displayExecutionReport(execution) {
            document.getElementById('loadingIndicator').style.display = 'none';
            document.getElementById('reportContent').style.display = 'block';

            // Header
            document.getElementById('testCaseName').textContent = execution.testCaseName || 'Test Case Execution';
            document.getElementById('testCaseDescription').textContent = 
                `Executed on ${new Date(execution.startedAt).toLocaleString()}`;

            // Summary
            const statusCard = document.getElementById('statusCard');
            statusCard.className = 'summary-card ' + (execution.success ? 'success' : 'failed');
            document.getElementById('statusValue').textContent = execution.status;
            document.getElementById('durationValue').textContent = formatDuration(execution.totalExecutionTimeMs);
            document.getElementById('stepsValue').textContent = execution.stepResults.length;
            
            const successCount = execution.stepResults.filter(s => s.success).length;
            const totalSteps = execution.stepResults.length;
            const successRate = totalSteps > 0 ? Math.round((successCount / totalSteps) * 100) : 0;
            document.getElementById('successRate').textContent = successRate + '%';

            // Setup Operations
            renderOperations('setupOperations', execution.setupResults);

            // Test Steps
            renderSteps('testSteps', execution.stepResults);

            // Teardown Operations
            renderOperations('teardownOperations', execution.teardownResults);
        }

        function renderOperations(containerId, operations) {
            const container = document.getElementById(containerId);
            if (!operations || operations.length === 0) {
                container.innerHTML = '<p style="color: #999; padding: 10px;">No operations</p>';
                return;
            }

            container.innerHTML = operations.map(op => `
                <div class="operation-item">
                    <div class="operation-name">
                        <i class="fas fa-${op.success ? 'check-circle icon-success' : 'times-circle icon-failed'}"></i>
                        <span>${op.operationName}</span>
                    </div>
                    <div>
                        <span class="time-badge">${formatDuration(op.executionTimeMs)}</span>
                    </div>
                </div>
                ${op.errorMessage ? `<div class="error-message"><i class="fas fa-exclamation-triangle"></i> ${op.errorMessage}</div>` : ''}
            `).join('');
        }

        function renderSteps(containerId, steps) {
            const container = document.getElementById(containerId);
            if (!steps || steps.length === 0) {
                container.innerHTML = '<p style="color: #999; padding: 10px;">No steps</p>';
                return;
            }

            container.innerHTML = steps.map((step, index) => `
                <div class="step-item ${step.success ? 'success' : 'failed'}">
                    <div class="step-header" onclick="toggleStep(${index})">
                        <div class="left">
                            <span class="step-name">${step.stepName}</span>
                            <span class="status-badge ${step.success ? 'success' : 'failed'}">
                                ${step.success ? '✓ Passed' : '✗ Failed'}
                            </span>
                        </div>
                        <div>
                            <span class="time-badge">${formatDuration(step.executionTimeMs)}</span>
                        </div>
                    </div>
                    <div id="step-${index}-content" class="collapsible-content">
                        ${renderActions(step.actionResults)}
                        ${step.errorMessage ? `<div class="error-message"><i class="fas fa-exclamation-triangle"></i> ${step.errorMessage}</div>` : ''}
                    </div>
                </div>
            `).join('');
        }

        function renderActions(actions) {
            if (!actions || actions.length === 0) {
                return '<p style="color: #999; padding: 10px;">No actions</p>';
            }

            return `
                <div class="action-container">
                    ${actions.map(action => `
                        <div class="action-item">
                            <div class="action-header">
                                <div class="action-name">
                                    <i class="fas fa-${action.success ? 'check icon-success' : 'times icon-failed'}"></i>
                                    ${action.actionName}
                                </div>
                                <span class="time-badge">${formatDuration(action.executionTimeMs)}</span>
                            </div>
                            
                            ${action.preConditionResults.length > 0 ? `
                                <div style="margin-top: 10px;">
                                    <strong style="font-size: 12px; color: #666;">Pre-conditions:</strong>
                                    <div class="operations-list">
                                        ${renderOperationResults(action.preConditionResults)}
                                    </div>
                                </div>
                            ` : ''}
                            
                            ${action.operationResults.length > 0 ? `
                                <div style="margin-top: 10px;">
                                    <strong style="font-size: 12px; color: #666;">Operations:</strong>
                                    <div class="operations-list">
                                        ${renderOperationResults(action.operationResults)}
                                    </div>
                                </div>
                            ` : ''}
                            
                            ${action.postConditionResults.length > 0 ? `
                                <div style="margin-top: 10px;">
                                    <strong style="font-size: 12px; color: #666;">Post-conditions:</strong>
                                    <div class="operations-list">
                                        ${renderOperationResults(action.postConditionResults)}
                                    </div>
                                </div>
                            ` : ''}
                            
                            ${action.errorMessage ? `<div class="error-message"><i class="fas fa-exclamation-triangle"></i> ${action.errorMessage}</div>` : ''}
                        </div>
                    `).join('')}
                </div>
            `;
        }

        function renderOperationResults(operations) {
            return operations.map(op => `
                <div class="operation-item">
                    <div class="operation-name">
                        <i class="fas fa-${op.success ? 'check-circle icon-success' : 'times-circle icon-failed'}"></i>
                        <span>${op.operationName}</span>
                    </div>
                    <span class="time-badge">${formatDuration(op.executionTimeMs)}</span>
                </div>
                ${op.errorMessage ? `<div class="error-message" style="margin-top: 5px;"><i class="fas fa-exclamation-triangle"></i> ${op.errorMessage}</div>` : ''}
            `).join('');
        }

        function toggleStep(index) {
            const content = document.getElementById(`step-${index}-content`);
            content.classList.toggle('open');
        }

        function formatDuration(ms) {
            if (ms < 1000) return `${Math.round(ms)}ms`;
            if (ms < 60000) return `${(ms / 1000).toFixed(2)}s`;
            const minutes = Math.floor(ms / 60000);
            const seconds = ((ms % 60000) / 1000).toFixed(0);
            return `${minutes}m ${seconds}s`;
        }

        function showNoData() {
            document.getElementById('loadingIndicator').style.display = 'none';
            document.getElementById('noData').style.display = 'block';
        }
    </script>
</body>
</html>
