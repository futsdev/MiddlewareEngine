@page
@model EditModel
@{
    ViewData["Title"] = "Edit Function";
}

<nav aria-label="breadcrumb" style="margin-bottom:1.5rem;">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/Dashboard"><i class="bi bi-house-door"></i> Home</a></li>
        <li class="breadcrumb-item"><a href="/Index"><i class="bi bi-list-ul"></i> Functions</a></li>
        <li class="breadcrumb-item active" aria-current="page"><i class="bi bi-pencil"></i> Edit</li>
    </ol>
</nav>

<div class="page-header">
    <h1><i class="bi bi-pencil"></i> Edit Function Definition</h1>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form method="post">
    <input type="hidden" asp-for="Function.Id" />
    
    <!-- Basic Information -->
    <div class="card mb-4">
        <div class="card-header">
            <i class="bi bi-info-circle"></i> Basic Information
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Function.FunctionId" class="form-label">Function ID *</label>
                    <input asp-for="Function.FunctionId" class="form-control" required />
                    <small class="text-muted">Unique identifier for this function</small>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Function.Name" class="form-label">Function Name *</label>
                    <input asp-for="Function.Name" class="form-control" required />
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Function.Description" class="form-label">Description</label>
                <textarea asp-for="Function.Description" class="form-control" rows="2"></textarea>
            </div>
            <div class="form-check">
                <input asp-for="Function.IsActive" class="form-check-input" type="checkbox" />
                <label asp-for="Function.IsActive" class="form-check-label">Active</label>
            </div>
        </div>
    </div>

    <!-- Execution Type -->
    <div class="card mb-4">
        <div class="card-header">
            <i class="bi bi-gear"></i> Execution Type
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Execution Type</label>
                    <select asp-for="Function.ExecutionType" class="form-select" id="executionTypeSelect">
                        <option value="RestApi">REST API</option>
                        <option value="ScpiCommand">SCPI Command</option>
                        <option value="SdkMethod">SDK Method</option>
                        <option value="Ssh">SSH Command</option>
                        <option value="Custom">Custom</option>
                    </select>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Operation Type</label>
                    <select asp-for="Function.OperationType" class="form-select" id="operationTypeSelect">
                        <option value="READ">READ - Query/retrieve data</option>
                        <option value="WRITE">WRITE - Send commands/data</option>
                        <option value="FILE_UPLOAD">FILE UPLOAD - Upload files</option>
                        <option value="FILE_DOWNLOAD">FILE DOWNLOAD - Download files</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <!-- Dynamic Configuration -->
    <div class="card mb-4">
        <div class="card-header">
            <i class="bi bi-sliders"></i> Configuration
        </div>
        <div class="card-body" id="configurationContainer">
            <!-- REST API -->
            <div class="config-section" data-type="RestApi" style="display: none;">
                <div class="row">
                    <div class="col-md-8 mb-3">
                        <label class="form-label">API URL</label>
                        <input asp-for="Function.ExecutionConfig.Url" class="form-control" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">HTTP Method</label>
                        <select asp-for="Function.ExecutionConfig.HttpMethod" class="form-select">
                            <option value="GET">GET</option>
                            <option value="POST">POST</option>
                            <option value="PUT">PUT</option>
                            <option value="DELETE">DELETE</option>
                        </select>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Timeout (seconds)</label>
                    <input asp-for="Function.ExecutionConfig.Timeout" type="number" class="form-control" />
                </div>
            </div>

            <!-- SCPI -->
            <div class="config-section" data-type="ScpiCommand" style="display: none;">
                <div class="mb-3">
                    <label class="form-label">SCPI Command</label>
                    <input asp-for="Function.ExecutionConfig.ScpiCommand" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Connection String</label>
                    <input asp-for="Function.ExecutionConfig.ConnectionString" class="form-control" />
                </div>
            </div>

            <!-- SSH -->
            <div class="config-section" data-type="Ssh" style="display: none;">
                <div class="row">
                    <div class="col-md-8 mb-3">
                        <label class="form-label">Host/IP Address</label>
                        <input asp-for="Function.ExecutionConfig.SshHost" class="form-control" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Port</label>
                        <input asp-for="Function.ExecutionConfig.SshPort" type="number" class="form-control" />
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Username</label>
                        <input asp-for="Function.ExecutionConfig.SshUsername" class="form-control" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Password</label>
                        <input asp-for="Function.ExecutionConfig.SshPassword" type="password" class="form-control" />
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">SSH Key Path</label>
                    <input asp-for="Function.ExecutionConfig.SshKeyPath" class="form-control" />
                    <small class="text-muted">Alternative to password</small>
                </div>
                <div class="mb-3">
                    <label class="form-label">Remote Path (for file operations)</label>
                    <input asp-for="Function.ExecutionConfig.RemotePath" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Local Path (for file operations)</label>
                    <input asp-for="Function.ExecutionConfig.LocalPath" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Max File Size (MB)</label>
                    <input asp-for="Function.ExecutionConfig.MaxFileSizeMb" type="number" class="form-control" />
                </div>
            </div>

            <!-- SDK Method -->
            <div class="config-section" data-type="SdkMethod" style="display: none;">
                <div class="mb-3">
                    <label class="form-label">Assembly Name</label>
                    <input asp-for="Function.ExecutionConfig.AssemblyName" class="form-control" id="assemblyName" />
                    <button type="button" class="btn btn-sm btn-outline-secondary mt-2" onclick="loadAssemblies()">
                        <i class="bi bi-arrow-clockwise"></i> Load Assemblies
                    </button>
                </div>
                <div class="mb-3">
                    <label class="form-label">Class Name</label>
                    <input asp-for="Function.ExecutionConfig.ClassName" class="form-control" id="className" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Method Name</label>
                    <input asp-for="Function.ExecutionConfig.MethodName" class="form-control" id="methodName" />
                </div>
            </div>
        </div>
    </div>

    <!-- Parameters -->
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-sliders"></i> Parameters</span>
            <button type="button" class="btn btn-sm btn-light" onclick="addParameter()">
                <i class="bi bi-plus"></i> Add Parameter
            </button>
        </div>
        <div class="card-body">
            <div id="parametersContainer"></div>
            <input type="hidden" asp-for="ParametersJson" id="parametersJson" />
        </div>
    </div>

    <!-- Actions -->
    <div class="d-flex justify-content-between">
        <a asp-page="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Cancel
        </a>
        <button type="submit" class="btn btn-primary btn-lg">
            <i class="bi bi-save"></i> Update Function
        </button>
    </div>
</form>

@section Scripts {
    <script>
        let parameters = @Html.Raw(Model.ParametersJson);
        
        // Show appropriate config section
        document.getElementById('executionTypeSelect').addEventListener('change', function() {
            showConfigSection(this.value);
        });
        
        function showConfigSection(type) {
            document.querySelectorAll('.config-section').forEach(s => s.style.display = 'none');
            const section = document.querySelector(`.config-section[data-type="${type}"]`);
            if (section) section.style.display = 'block';
        }
        
        // Initialize
        showConfigSection('@Model.Function.ExecutionType');
        renderParameters();
        
        // Parameter management (same as Create page)
        function addParameter() {
            parameters.push({
                name: '',
                type: 'string',
                required: true,
                description: ''
            });
            renderParameters();
        }
        
        function removeParameter(index) {
            parameters.splice(index, 1);
            renderParameters();
        }
        
        function renderParameters() {
            const container = document.getElementById('parametersContainer');
            if (parameters.length === 0) {
                container.innerHTML = '<p class="text-muted">No parameters defined.</p>';
                return;
            }
            
            container.innerHTML = parameters.map((param, index) => `
                <div class="parameter-item card mb-2">
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-3">
                                <input type="text" class="form-control form-control-sm" placeholder="Parameter name"
                                       value="${param.name || ''}" onchange="updateParameter(${index}, 'name', this.value)" />
                            </div>
                            <div class="col-md-2">
                                <input type="text" class="form-control form-control-sm" placeholder="Type"
                                       value="${param.type || 'string'}" onchange="updateParameter(${index}, 'type', this.value)" />
                            </div>
                            <div class="col-md-4">
                                <input type="text" class="form-control form-control-sm" placeholder="Description"
                                       value="${param.description || ''}" onchange="updateParameter(${index}, 'description', this.value)" />
                            </div>
                            <div class="col-md-2">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" ${param.required ? 'checked' : ''}
                                           onchange="updateParameter(${index}, 'required', this.checked)" />
                                    <label class="form-check-label">Required</label>
                                </div>
                            </div>
                            <div class="col-md-1 text-end">
                                <button type="button" class="btn btn-sm btn-danger" onclick="removeParameter(${index})">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            `).join('');
            
            document.getElementById('parametersJson').value = JSON.stringify(parameters);
        }
        
        function updateParameter(index, field, value) {
            parameters[index][field] = value;
            document.getElementById('parametersJson').value = JSON.stringify(parameters);
        }

        async function loadAssemblies() {
            try {
                const response = await fetch('/api/assemblies');
                const assemblies = await response.json();
                
                const assemblyInput = document.getElementById('assemblyName');
                const datalist = document.createElement('datalist');
                datalist.id = 'assembliesList';
                assemblies.forEach(a => {
                    const option = document.createElement('option');
                    option.value = a;
                    datalist.appendChild(option);
                });
                
                document.body.appendChild(datalist);
                assemblyInput.setAttribute('list', 'assembliesList');
                
                showToast('Assemblies loaded! Start typing to see suggestions.', 'success');
            } catch (error) {
                showToast('Failed to load assemblies: ' + error.message, 'error');
            }
        }
    </script>
}
