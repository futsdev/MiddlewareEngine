<script>
    let currentDate = new Date();
    let allProjects = [];
    let allSetups = [];
    let allInstruments = [];
    
    document.addEventListener('DOMContentLoaded', async function() {
        await loadData();
        renderCalendar();
        updateResourceOverview();
    });
    
    async function loadData() {
        try {
            const [projects, setups, instruments] = await Promise.all([
                fetch('/api/projects').then(r => r.json()),
                fetch('/api/setups').then(r => r.json()),
                fetch('/api/instruments').then(r => r.json())
            ]);
            
            allProjects = projects;
            allSetups = setups;
            allInstruments = instruments;
        } catch (error) {
            console.error('Error loading data:', error);
        }
    }
    
    function renderCalendar() {
        const year = currentDate.getFullYear();
        const month = currentDate.getMonth();
        
        document.getElementById('currentMonth').textContent = 
            currentDate.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
        
        const firstDay = new Date(year, month, 1);
        const lastDay = new Date(year, month + 1, 0);
        const startDay = firstDay.getDay();
        const daysInMonth = lastDay.getDate();
        
        const container = document.getElementById('calendarDays');
        container.innerHTML = '';
        
        const today = new Date();
        const isCurrentMonth = today.getFullYear() === year && today.getMonth() === month;
        
        for (let i = 0; i < startDay; i++) {
            const prevMonthDay = new Date(year, month, 0 - (startDay - i - 1));
            const dayDiv = createDayCell(prevMonthDay, true);
            container.appendChild(dayDiv);
        }
        
        for (let day = 1; day <= daysInMonth; day++) {
            const date = new Date(year, month, day);
            const dayDiv = createDayCell(date, false, isCurrentMonth && day === today.getDate());
            container.appendChild(dayDiv);
        }
        
        const remainingDays = 42 - (startDay + daysInMonth);
        for (let i = 1; i <= remainingDays; i++) {
            const nextMonthDay = new Date(year, month + 1, i);
            const dayDiv = createDayCell(nextMonthDay, true);
            container.appendChild(dayDiv);
        }
    }
    
    function createDayCell(date, otherMonth, isToday = false) {
        const div = document.createElement('div');
        div.className = 'calendar-day' + (otherMonth ? ' other-month' : '') + (isToday ? ' today' : '');
        
        const dayNum = document.createElement('div');
        dayNum.className = 'day-number';
        dayNum.textContent = date.getDate();
        div.appendChild(dayNum);
        
        const eventsDiv = document.createElement('div');
        eventsDiv.className = 'day-events';
        
        const dateStr = date.toISOString().split('T')[0];
        const dayEvents = getEventsForDate(date);
        
        dayEvents.forEach(event => {
            const eventDiv = document.createElement('div');
            eventDiv.className = 'event-item ' + event.type;
            eventDiv.textContent = event.title;
            eventDiv.title = event.details;
            eventsDiv.appendChild(eventDiv);
        });
        
        div.appendChild(eventsDiv);
        return div;
    }
    
    function getEventsForDate(date) {
        const events = [];
        const dateTime = date.getTime();
        
        allProjects.forEach(project => {
            if (project.startDate && project.endDate) {
                const start = new Date(project.startDate).getTime();
                const end = new Date(project.endDate).getTime();
                
                if (dateTime >= start && dateTime <= end) {
                    events.push({
                        type: 'event-project',
                        title: project.name,
                        details: 'Project: ' + project.name + ' (Customer: ' + (project.customerName || 'N/A') + ')'
                    });
                }
            }
        });
        
        allSetups.forEach(setup => {
            const isInUse = allProjects.some(p => {
                if (p.startDate && p.endDate && (p.setupIds || []).includes(setup.id)) {
                    const start = new Date(p.startDate).getTime();
                    const end = new Date(p.endDate).getTime();
                    return dateTime >= start && dateTime <= end;
                }
                return false;
            });
            
            if (events.length < 3) {
                events.push({
                    type: isInUse ? 'event-setup-busy' : 'event-setup-free',
                    title: setup.name,
                    details: 'Setup: ' + setup.name + ' - ' + (isInUse ? 'In Use' : 'Available')
                });
            }
        });
        
        return events.slice(0, 3);
    }
    
    function updateResourceOverview() {
        const today = new Date();
        
        let setupHtml = '';
        allSetups.forEach(setup => {
            const isInUse = allProjects.some(p => {
                if (p.startDate && p.endDate && (p.setupIds || []).includes(setup.id)) {
                    const start = new Date(p.startDate);
                    const end = new Date(p.endDate);
                    return today >= start && today <= end;
                }
                return false;
            });
            
            setupHtml += '<div class="resource-item ' + (isInUse ? 'busy' : 'available') + '">' +
                '<div class="resource-name">' + (setup.name || 'Unnamed') + '</div>' +
                '<div class="resource-status">' + (setup.type || 'N/A') + ' - ' + 
                (isInUse ? 'Currently in use' : 'Available') + '</div>' +
                '</div>';
        });
        document.getElementById('setupAvailability').innerHTML = setupHtml || '<div style="text-align: center; color: #94a3b8; padding: 1rem;">No setups found</div>';
        
        let projectHtml = '';
        allProjects.forEach(project => {
            if (project.startDate && project.endDate) {
                const start = new Date(project.startDate);
                const end = new Date(project.endDate);
                if (today >= start && today <= end) {
                    const daysLeft = Math.ceil((end - today) / (1000 * 60 * 60 * 24));
                    projectHtml += '<div class="resource-item ' + (daysLeft > 7 ? 'available' : 'busy') + '">' +
                        '<div class="resource-name">' + (project.name || 'Unnamed') + '</div>' +
                        '<div class="resource-status">' + (project.customerName || 'No customer') + ' - ' +
                        daysLeft + ' days remaining</div>' +
                        '</div>';
                }
            }
        });
        document.getElementById('activeProjects').innerHTML = projectHtml || '<div style="text-align: center; color: #94a3b8; padding: 1rem;">No active projects</div>';
        
        let instrumentHtml = '';
        allInstruments.forEach(inst => {
            const isAvailable = inst.status === 'Available';
            instrumentHtml += '<div class="resource-item ' + (isAvailable ? 'available' : 'busy') + '">' +
                '<div class="resource-name">' + (inst.name || 'Unnamed') + '</div>' +
                '<div class="resource-status">' + (inst.manufacturer || 'N/A') + ' - ' + 
                (inst.status || 'Unknown') + '</div>' +
                '</div>';
        });
        document.getElementById('instrumentStatus').innerHTML = instrumentHtml || '<div style="text-align: center; color: #94a3b8; padding: 1rem;">No instruments found</div>';
    }
    
    function previousMonth() {
        currentDate.setMonth(currentDate.getMonth() - 1);
        renderCalendar();
    }
    
    function nextMonth() {
        currentDate.setMonth(currentDate.getMonth() + 1);
        renderCalendar();
    }
    
    function goToToday() {
        currentDate = new Date();
        renderCalendar();
    }
    
    function switchView(view) {
        document.querySelectorAll('.view-tab').forEach(tab => tab.classList.remove('active'));
        event.target.closest('.view-tab').classList.add('active');
        
        document.getElementById('calendarView').classList.remove('active');
        document.getElementById('timelineView').classList.remove('active');
        document.getElementById('resourceView').classList.remove('active');
        
        if (view === 'calendar') {
            document.getElementById('calendarView').classList.add('active');
        } else if (view === 'timeline') {
            document.getElementById('timelineView').classList.add('active');
            renderTimeline('all');
        } else if (view === 'resources') {
            document.getElementById('resourceView').classList.add('active');
            renderResourceView('setups');
        }
    }
    
    function renderTimeline(filter) {
        const container = document.getElementById('timelineItems');
        const today = new Date();
        
        let filteredProjects = allProjects.filter(p => p.startDate && p.endDate);
        
        if (filter === 'active') {
            filteredProjects = filteredProjects.filter(p => {
                const start = new Date(p.startDate);
                const end = new Date(p.endDate);
                return today >= start && today <= end;
            });
        } else if (filter === 'upcoming') {
            filteredProjects = filteredProjects.filter(p => {
                const start = new Date(p.startDate);
                return today < start;
            });
        } else if (filter === 'completed') {
            filteredProjects = filteredProjects.filter(p => {
                const end = new Date(p.endDate);
                return today > end;
            });
        }
        
        filteredProjects.sort((a, b) => new Date(a.startDate) - new Date(b.startDate));
        
        if (filteredProjects.length === 0) {
            container.innerHTML = '<div style="text-align: center; color: #94a3b8; padding: 2rem;">No projects found for this filter</div>';
            return;
        }
        
        let html = '';
        filteredProjects.forEach(project => {
            const start = new Date(project.startDate);
            const end = new Date(project.endDate);
            const totalDays = Math.ceil((end - start) / (1000 * 60 * 60 * 24));
            const elapsedDays = Math.max(0, Math.ceil((today - start) / (1000 * 60 * 60 * 24)));
            const progress = Math.min(100, Math.max(0, (elapsedDays / totalDays) * 100));
            const daysLeft = Math.ceil((end - today) / (1000 * 60 * 60 * 24));
            
            let progressClass = '';
            if (daysLeft < 0) progressClass = 'danger';
            else if (daysLeft < 7) progressClass = 'warning';
            
            const setupCount = (project.setupIds || []).length;
            let instrumentCount = 0;
            (project.setupIds || []).forEach(sid => {
                const setup = allSetups.find(s => s.id === sid);
                if (setup) instrumentCount += (setup.instrumentIds || []).length;
            });
            
            html += '<div class="timeline-item">' +
                '<div class="timeline-item-header">' +
                    '<div>' +
                        '<div class="timeline-item-title">' + (project.name || 'Unnamed Project') + '</div>' +
                        '<div class="timeline-item-customer"><i class="bi bi-person-badge"></i> ' + (project.customerName || 'No customer') + 
                        (project.customerCompany ? ' - ' + project.customerCompany : '') + '</div>' +
                    '</div>' +
                    '<div style="text-align: right;">' +
                        '<span style="font-size: 0.875rem; color: #64748b;">Status: <strong style="color:' + 
                        (daysLeft < 0 ? '#ef4444' : daysLeft < 7 ? '#f59e0b' : '#10b981') + ';">' +
                        (daysLeft < 0 ? 'Overdue' : daysLeft === 0 ? 'Due Today' : daysLeft + ' days left') + '</strong></span>' +
                    '</div>' +
                '</div>' +
                '<div class="timeline-item-dates">' +
                    '<div class="timeline-date"><i class="bi bi-calendar-check"></i> Start: ' + start.toLocaleDateString() + '</div>' +
                    '<div class="timeline-date"><i class="bi bi-calendar-x"></i> End: ' + end.toLocaleDateString() + '</div>' +
                    '<div class="timeline-date"><i class="bi bi-clock"></i> Duration: ' + totalDays + ' days</div>' +
                '</div>' +
                '<div class="timeline-progress-bar">' +
                    '<div class="timeline-progress-fill ' + progressClass + '" style="width: ' + progress + '%"></div>' +
                '</div>' +
                '<div class="timeline-item-details">' +
                    '<div class="timeline-detail"><i class="bi bi-diagram-3"></i> ' + setupCount + ' Setup(s)</div>' +
                    '<div class="timeline-detail"><i class="bi bi-hdd-rack"></i> ' + instrumentCount + ' Instrument(s)</div>' +
                    '<div class="timeline-detail"><i class="bi bi-percent"></i> ' + Math.round(progress) + '% Complete</div>' +
                '</div>' +
                '</div>';
        });
        
        container.innerHTML = html;
    }
    
    function filterTimeline(filter) {
        document.querySelectorAll('.timeline-filter-btn').forEach(btn => btn.classList.remove('active'));
        event.target.classList.add('active');
        renderTimeline(filter);
    }
    
    function renderResourceView(type) {
        const container = document.getElementById('resourceGrid');
        const today = new Date();
        
        if (type === 'setups') {
            if (allSetups.length === 0) {
                container.innerHTML = '<div style="text-align: center; color: #94a3b8; padding: 2rem;">No setups found</div>';
                return;
            }
            
            let html = '';
            allSetups.forEach(setup => {
                const assignedProjects = allProjects.filter(p => {
                    if (p.startDate && p.endDate && (p.setupIds || []).includes(setup.id)) {
                        const start = new Date(p.startDate);
                        const end = new Date(p.endDate);
                        return today >= start && today <= end;
                    }
                    return false;
                });
                
                const isInUse = assignedProjects.length > 0;
                const instrumentCount = (setup.instrumentIds || []).length;
                
                html += '<div class="resource-detail-card">' +
                    '<div class="resource-detail-header">' +
                        '<div>' +
                            '<div class="resource-detail-title">' + (setup.name || 'Unnamed Setup') + '</div>' +
                            '<div class="resource-detail-subtitle">' + (setup.type || 'N/A') + '</div>' +
                        '</div>' +
                        '<div class="resource-status-badge ' + (isInUse ? 'in-use' : 'available') + '">' +
                            (isInUse ? 'In Use' : 'Available') +
                        '</div>' +
                    '</div>' +
                    '<div style="margin-top: 0.75rem; display: flex; gap: 1.5rem; font-size: 0.875rem; color: #64748b;">' +
                        '<div><i class="bi bi-hdd-rack"></i> ' + instrumentCount + ' Instrument(s)</div>' +
                        '<div><i class="bi bi-folder"></i> ' + assignedProjects.length + ' Active Project(s)</div>' +
                    '</div>';
                
                if (assignedProjects.length > 0) {
                    html += '<div class="resource-assignments">' +
                        '<div class="assignment-title">Current Assignments:</div>' +
                        '<div class="assignment-list">';
                    
                    assignedProjects.forEach(proj => {
                        const end = new Date(proj.endDate);
                        const daysLeft = Math.ceil((end - today) / (1000 * 60 * 60 * 24));
                        html += '<div class="assignment-item">' +
                            '<span class="assignment-name">' + (proj.name || 'Unnamed') + '</span>' +
                            '<span style="color: ' + (daysLeft < 7 ? '#ef4444' : '#10b981') + ';">' + daysLeft + ' days left</span>' +
                            '</div>';
                    });
                    
                    html += '</div></div>';
                }
                
                html += '</div>';
            });
            
            container.innerHTML = html;
        } else if (type === 'instruments') {
            if (allInstruments.length === 0) {
                container.innerHTML = '<div style="text-align: center; color: #94a3b8; padding: 2rem;">No instruments found</div>';
                return;
            }
            
            let html = '';
            allInstruments.forEach(inst => {
                const assignedSetups = allSetups.filter(s => (s.instrumentIds || []).includes(inst.id));
                const activeProjects = [];
                
                assignedSetups.forEach(setup => {
                    const projects = allProjects.filter(p => {
                        if (p.startDate && p.endDate && (p.setupIds || []).includes(setup.id)) {
                            const start = new Date(p.startDate);
                            const end = new Date(p.endDate);
                            return today >= start && today <= end;
                        }
                        return false;
                    });
                    activeProjects.push(...projects);
                });
                
                const uniqueProjects = [...new Set(activeProjects.map(p => p.id))].map(id => 
                    activeProjects.find(p => p.id === id)
                );
                
                let statusClass = 'available';
                if (inst.status === 'In Use' || uniqueProjects.length > 0) statusClass = 'in-use';
                else if (inst.status === 'Maintenance') statusClass = 'maintenance';
                
                html += '<div class="resource-detail-card">' +
                    '<div class="resource-detail-header">' +
                        '<div>' +
                            '<div class="resource-detail-title">' + (inst.name || 'Unnamed Instrument') + '</div>' +
                            '<div class="resource-detail-subtitle">' + (inst.manufacturer || 'N/A') + ' ' + (inst.model || '') + '</div>' +
                        '</div>' +
                        '<div class="resource-status-badge ' + statusClass + '">' +
                            (inst.status || 'Unknown') +
                        '</div>' +
                    '</div>' +
                    '<div style="margin-top: 0.75rem; display: flex; gap: 1.5rem; font-size: 0.875rem; color: #64748b;">' +
                        '<div><i class="bi bi-diagram-3"></i> ' + assignedSetups.length + ' Setup(s)</div>' +
                        '<div><i class="bi bi-folder"></i> ' + uniqueProjects.length + ' Active Project(s)</div>' +
                    '</div>';
                
                if (uniqueProjects.length > 0) {
                    html += '<div class="resource-assignments">' +
                        '<div class="assignment-title">Active in Projects:</div>' +
                        '<div class="assignment-list">';
                    
                    uniqueProjects.forEach(proj => {
                        const end = new Date(proj.endDate);
                        const daysLeft = Math.ceil((end - today) / (1000 * 60 * 60 * 24));
                        html += '<div class="assignment-item">' +
                            '<span class="assignment-name">' + (proj.name || 'Unnamed') + '</span>' +
                            '<span style="color: ' + (daysLeft < 7 ? '#ef4444' : '#10b981') + ';">' + daysLeft + ' days left</span>' +
                            '</div>';
                    });
                    
                    html += '</div></div>';
                }
                
                html += '</div>';
            });
            
            container.innerHTML = html;
        }
    }
    
    function switchResourceType(type) {
        document.querySelectorAll('.resource-type-tab').forEach(tab => tab.classList.remove('active'));
        event.target.closest('.resource-type-tab').classList.add('active');
        renderResourceView(type);
    }
</script>
