@page
@model MiddlewareEngine.Pages.RolesModel
@{
    ViewData["Title"] = "Roles";
}

<style>
    .page-header {
        background: linear-gradient(135deg, #06b6d4 0%, #0891b2 100%);
        color: white;
        padding: 1.25rem;
        border-radius: 10px;
        margin-bottom: 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    
    .search-filter-bar {
        background: white;
        padding: 1rem;
        border-radius: 10px;
        margin-bottom: 1rem;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        display: flex;
        gap: 1rem;
        align-items: center;
    }
    
    .search-input {
        flex: 1;
        max-width: 400px;
        padding: 0.625rem 1rem;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        font-size: 0.875rem;
    }
    
    .table-container {
        background: white;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        overflow: hidden;
    }
    
    .data-table {
        width: 100%;
        border-collapse: collapse;
    }
    
    .data-table th {
        background: #f8fafc;
        padding: 1rem;
        text-align: left;
        font-weight: 700;
        font-size: 0.8125rem;
        color: #64748b;
        border-bottom: 2px solid #e5e7eb;
    }
    
    .data-table td {
        padding: 1rem;
        border-bottom: 1px solid #e5e7eb;
        font-size: 0.875rem;
    }
    
    .data-table tr:hover {
        background: #f8fafc;
    }
    
    .action-btn {
        padding: 0.375rem 0.75rem;
        border-radius: 6px;
        font-size: 0.8125rem;
        font-weight: 600;
        text-decoration: none;
        margin-right: 0.5rem;
        transition: all 0.2s;
    }
    
    .btn-edit {
        background: #dbeafe;
        color: #2563eb;
    }
    
    .btn-edit:hover {
        background: #2563eb;
        color: white;
    }
    
    .btn-delete {
        background: #fee2e2;
        color: #dc2626;
        border: none;
        cursor: pointer;
    }
    
    .btn-delete:hover {
        background: #dc2626;
        color: white;
    }
    
    .pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.5rem;
        padding: 1.5rem;
        background: white;
        border-radius: 0 0 10px 10px;
    }
    
    .pagination-btn {
        padding: 0.5rem 1rem;
        border: 1px solid #e5e7eb;
        background: white;
        border-radius: 6px;
        cursor: pointer;
        font-size: 0.875rem;
        font-weight: 600;
    }
    
    .pagination-btn:hover:not(:disabled) {
        background: #06b6d4;
        color: white;
        border-color: #06b6d4;
    }
    
    .pagination-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }
    
    .pagination-btn.active {
        background: #06b6d4;
        color: white;
        border-color: #06b6d4;
    }
    
    .badge {
        display: inline-block;
        padding: 0.25rem 0.5rem;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: 600;
        background: #e0f2fe;
        color: #0369a1;
    }
</style>

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/Dashboard">Home</a></li>
        <li class="breadcrumb-item active">Roles</li>
    </ol>
</nav>

<div class="page-header">
    <div>
        <h1 style="margin: 0; font-size: 1.5rem; font-weight: 700;"><i class="bi bi-shield-lock"></i> Role Management</h1>
        <p style="margin: 0.25rem 0 0 0; opacity: 0.9; font-size: 0.875rem;">Manage roles and permissions</p>
    </div>
    <a href="/Roles/Create" class="btn btn-light"><i class="bi bi-plus-circle"></i> Add Role</a>
</div>

<div class="search-filter-bar">
    <input type="text" id="searchInput" class="search-input" placeholder="Search roles by name or description...">
    <button onclick="clearFilters()" class="btn btn-outline-secondary btn-sm">Clear</button>
</div>

<div class="table-container">
    <table class="data-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Permissions</th>
                <th>Created</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody id="rolesTableBody">
            <tr>
                <td colspan="5" style="text-align: center; padding: 2rem;">Loading roles...</td>
            </tr>
        </tbody>
    </table>
    
    <div class="pagination" id="pagination">
    </div>
</div>

<script>
    let allRoles = [];
    let filteredRoles = [];
    let currentPage = 1;
    const pageSize = 10;
    
    document.addEventListener('DOMContentLoaded', function() {
        loadRoles();
        
        document.getElementById('searchInput').addEventListener('input', function() {
            filterRoles();
        });
    });
    
    async function loadRoles() {
        try {
            const response = await fetch('/api/roles');
            allRoles = await response.json();
            filteredRoles = allRoles;
            renderRoles();
        } catch (error) {
            console.error('Error loading roles:', error);
            document.getElementById('rolesTableBody').innerHTML = 
                '<tr><td colspan="5" style="text-align: center; color: #dc2626;">Error loading roles</td></tr>';
        }
    }
    
    function filterRoles() {
        const searchTerm = document.getElementById('searchInput').value.toLowerCase();
        
        filteredRoles = allRoles.filter(function(role) {
            const matchesSearch = !searchTerm || 
                (role.name && role.name.toLowerCase().indexOf(searchTerm) !== -1) ||
                (role.description && role.description.toLowerCase().indexOf(searchTerm) !== -1);
            
            return matchesSearch;
        });
        
        currentPage = 1;
        renderRoles();
    }
    
    function renderRoles() {
        const tbody = document.getElementById('rolesTableBody');
        
        if (filteredRoles.length === 0) {
            tbody.innerHTML = '<tr><td colspan="5" style="text-align: center; padding: 2rem;">No roles found</td></tr>';
            document.getElementById('pagination').innerHTML = '';
            return;
        }
        
        const startIndex = (currentPage - 1) * pageSize;
        const endIndex = startIndex + pageSize;
        const paginatedRoles = filteredRoles.slice(startIndex, endIndex);
        
        tbody.innerHTML = paginatedRoles.map(function(role) {
            const permissionsCount = role.permissions ? role.permissions.length : 0;
            const createdDate = role.createdAt ? new Date(role.createdAt).toLocaleDateString() : 'N/A';
            
            return '<tr>' +
                '<td><strong>' + (role.name || 'N/A') + '</strong></td>' +
                '<td>' + (role.description || 'No description') + '</td>' +
                '<td><span class="badge">' + permissionsCount + ' permissions</span></td>' +
                '<td>' + createdDate + '</td>' +
                '<td>' +
                    '<a href="/Roles/Edit?id=' + role.id + '" class="action-btn btn-edit">Edit</a>' +
                    '<button onclick="deleteRole(\'' + role.id + '\')" class="action-btn btn-delete">Delete</button>' +
                '</td>' +
            '</tr>';
        }).join('');
        
        renderPagination();
    }
    
    function renderPagination() {
        const totalPages = Math.ceil(filteredRoles.length / pageSize);
        const pagination = document.getElementById('pagination');
        
        if (totalPages <= 1) {
            pagination.innerHTML = '';
            return;
        }
        
        let html = '<button class="pagination-btn" onclick="changePage(' + (currentPage - 1) + ')" ' + 
                   (currentPage === 1 ? 'disabled' : '') + '>Previous</button>';
        
        for (let i = 1; i <= totalPages; i++) {
            html += '<button class="pagination-btn ' + (i === currentPage ? 'active' : '') + '" ' +
                   'onclick="changePage(' + i + ')">' + i + '</button>';
        }
        
        html += '<button class="pagination-btn" onclick="changePage(' + (currentPage + 1) + ')" ' + 
                (currentPage === totalPages ? 'disabled' : '') + '>Next</button>';
        
        pagination.innerHTML = html;
    }
    
    function changePage(page) {
        const totalPages = Math.ceil(filteredRoles.length / pageSize);
        if (page < 1 || page > totalPages) return;
        currentPage = page;
        renderRoles();
    }
    
    function clearFilters() {
        document.getElementById('searchInput').value = '';
        filterRoles();
    }
    
    async function deleteRole(roleId) {
        if (!confirm('Are you sure you want to delete this role?')) {
            return;
        }
        
        try {
            const response = await fetch('/api/roles/' + roleId, {
                method: 'DELETE'
            });
            
            if (response.ok) {
                showToast('Role deleted successfully', 'success');
                loadRoles();
            } else {
                showToast('Failed to delete role', 'error');
            }
        } catch (error) {
            console.error('Error deleting role:', error);
            showToast('Error deleting role', 'error');
        }
    }
</script>
