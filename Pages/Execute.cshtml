@page
@model ExecuteModel
@{
    ViewData["Title"] = "Execute Function";
}

<nav aria-label="breadcrumb" style="margin-bottom:1.5rem;">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/Dashboard"><i class="bi bi-house-door"></i> Home</a></li>
        <li class="breadcrumb-item"><a href="/Index"><i class="bi bi-list-ul"></i> Functions</a></li>
        <li class="breadcrumb-item active" aria-current="page"><i class="bi bi-play-circle"></i> Execute</li>
    </ol>
</nav>

<div class="page-header">
    <h1><i class="bi bi-play-circle"></i> Execute Function</h1>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row">
    <div class="col-lg-6">
        <form method="post">
            <div class="card mb-4">
                <div class="card-header">
                    <i class="bi bi-gear"></i> Function Selection
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Select Function</label>
                        <select asp-for="FunctionId" class="form-select" id="functionSelect" required>
                            <option value="">-- Select a function --</option>
                            @foreach (var func in Model.Functions)
                            {
                                <option value="@func.FunctionId" 
                                        data-params='@System.Text.Json.JsonSerializer.Serialize(func.Parameters)'
                                        selected="@(func.FunctionId == Model.FunctionId)">
                                    @func.Name (@func.ExecutionType)
                                </option>
                            }
                        </select>
                    </div>
                </div>
            </div>

            <div class="card mb-4" id="parametersCard" style="display:none;">
                <div class="card-header">
                    <i class="bi bi-sliders"></i> Parameters
                </div>
                <div class="card-body" id="parametersForm">
                    <p class="text-muted">Select a function to see its parameters</p>
                </div>
            </div>

            <input type="hidden" asp-for="ParametersJson" id="parametersJson" />

            <button type="submit" class="btn btn-success btn-lg w-100">
                <i class="bi bi-play-fill"></i> Execute Function
            </button>
        </form>
    </div>

    <div class="col-lg-6">
        @if (Model.SelectedFunction != null)
        {
            <div class="card mb-4">
                <div class="card-header">
                    <i class="bi bi-info-circle"></i> Function Details
                </div>
                <div class="card-body">
                    <h5>@Model.SelectedFunction.Name</h5>
                    <p class="text-muted">@Model.SelectedFunction.Description</p>
                    
                    <div class="mb-2">
                        <strong>Function ID:</strong> <code>@Model.SelectedFunction.FunctionId</code>
                    </div>
                    <div class="mb-2">
                        <strong>Type:</strong> 
                        <span class="badge @(Model.SelectedFunction.ExecutionType switch {
                            "RestApi" => "badge-rest",
                            "ScpiCommand" => "badge-scpi",
                            "SdkMethod" => "badge-sdk",
                            _ => "bg-secondary"
                        })">
                            @Model.SelectedFunction.ExecutionType
                        </span>
                    </div>
                    
                    @if (Model.SelectedFunction.ExecutionType == "RestApi")
                    {
                        <div class="mt-3">
                            <strong>REST API:</strong><br/>
                            <code>@Model.SelectedFunction.ExecutionConfig.HttpMethod @Model.SelectedFunction.ExecutionConfig.Url</code>
                        </div>
                    }
                    else if (Model.SelectedFunction.ExecutionType == "ScpiCommand")
                    {
                        <div class="mt-3">
                            <strong>SCPI Command:</strong><br/>
                            <code>@Model.SelectedFunction.ExecutionConfig.ScpiCommand</code>
                        </div>
                    }
                    else if (Model.SelectedFunction.ExecutionType == "SdkMethod")
                    {
                        <div class="mt-3">
                            <strong>SDK Method:</strong><br/>
                            <code>@Model.SelectedFunction.ExecutionConfig.ClassName.@Model.SelectedFunction.ExecutionConfig.MethodName</code>
                        </div>
                    }
                </div>
            </div>
        }

        @if (Model.ExecutionResult != null)
        {
            <div class="card">
                <div class="card-header @(Model.ExecutionResult.Success ? "bg-success" : "bg-danger") text-white">
                    <i class="bi bi-@(Model.ExecutionResult.Success ? "check-circle" : "x-circle")"></i> 
                    Execution Result
                </div>
                <div class="card-body">
                    @if (Model.ExecutionResult.Success)
                    {
                        <div class="mb-3">
                            <strong>Status:</strong> <span class="badge bg-success">Success</span>
                        </div>
                        <div class="mb-3">
                            <strong>Result:</strong>
                            <pre class="bg-light p-3 rounded mt-2"><code>@System.Text.Json.JsonSerializer.Serialize(Model.ExecutionResult.Result, new System.Text.Json.JsonSerializerOptions { WriteIndented = true })</code></pre>
                        </div>
                    }
                    else
                    {
                        <div class="mb-3">
                            <strong>Status:</strong> <span class="badge bg-danger">Failed</span>
                        </div>
                        <div class="alert alert-danger mb-0">
                            <strong>Error:</strong> @Model.ExecutionResult.ErrorMessage
                        </div>
                    }
                    
                    <div class="mt-3">
                        <small class="text-muted">
                            <i class="bi bi-clock"></i> Executed at: @Model.ExecutionResult.ExecutedAt.ToString("yyyy-MM-dd HH:mm:ss")
                        </small>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        const functionSelect = document.getElementById('functionSelect');
        const parametersCard = document.getElementById('parametersCard');
        const parametersForm = document.getElementById('parametersForm');
        const parametersJson = document.getElementById('parametersJson');
        
        functionSelect.addEventListener('change', function() {
            const selected = this.options[this.selectedIndex];
            const paramsData = selected.dataset.params;
            
            if (!paramsData || paramsData === '[]') {
                parametersCard.style.display = 'none';
                parametersJson.value = '{}';
                return;
            }
            
            const params = JSON.parse(paramsData);
            renderParameterForm(params);
            parametersCard.style.display = 'block';
        });
        
        function renderParameterForm(params) {
            if (params.length === 0) {
                parametersForm.innerHTML = '<p class="text-muted">No parameters required</p>';
                parametersJson.value = '{}';
                return;
            }
            
            let html = '';
            params.forEach(param => {
                const required = param.Required ? 'required' : '';
                html += `
                    <div class="mb-3">
                        <label class="form-label">
                            ${param.Name} 
                            ${param.Required ? '<span class="text-danger">*</span>' : ''}
                            <small class="text-muted">(${param.Type})</small>
                        </label>
                        ${param.Description ? `<small class="d-block text-muted mb-1">${param.Description}</small>` : ''}
                        ${renderInput(param)}
                    </div>
                `;
            });
            
            parametersForm.innerHTML = html;
            
            // Add change listeners to update JSON
            parametersForm.querySelectorAll('input, select').forEach(input => {
                input.addEventListener('change', updateParametersJson);
            });
        }
        
        function renderInput(param) {
            const name = param.Name;
            if (param.Type === 'bool') {
                return `
                    <select class="form-select" data-param="${name}" ${param.Required ? 'required' : ''}>
                        <option value="">Select...</option>
                        <option value="true">True</option>
                        <option value="false">False</option>
                    </select>
                `;
            } else if (param.Type === 'int' || param.Type === 'double') {
                return `
                    <input type="number" class="form-control" data-param="${name}" 
                           step="${param.Type === 'double' ? 'any' : '1'}" 
                           ${param.Required ? 'required' : ''} />
                `;
            } else {
                return `
                    <input type="text" class="form-control" data-param="${name}" 
                           ${param.Required ? 'required' : ''} />
                `;
            }
        }
        
        function updateParametersJson() {
            const inputs = parametersForm.querySelectorAll('[data-param]');
            const params = {};
            
            inputs.forEach(input => {
                const name = input.dataset.param;
                let value = input.value;
                
                if (value) {
                    // Try to parse as number or boolean
                    if (!isNaN(value) && value !== '') {
                        value = Number(value);
                    } else if (value === 'true' || value === 'false') {
                        value = value === 'true';
                    }
                    params[name] = value;
                }
            });
            
            parametersJson.value = JSON.stringify(params);
        }
        
        // Trigger change if function is pre-selected
        if (functionSelect.value) {
            functionSelect.dispatchEvent(new Event('change'));
        }
    </script>
}
