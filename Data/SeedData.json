  {
    "function_id": "weather-by-city",
    "name": "Get Weather by City",
    "description": "Fetches current weather data for a given city using OpenWeatherMap API",
    "execution_type": "RestApi",
    "execution_config": {
      "url": "https://api.openweathermap.org/data/2.5/weather",
      "http_method": "GET",
      "headers": {
        "Accept": "application/json"
      },
      "timeout": 30
    },
    "parameters": [
      {
        "name": "q",
        "type": "string",
        "required": true,
        "description": "City name"
      },
      {
        "name": "appid",
        "type": "string",
        "required": true,
        "description": "API key"
      },
      {
        "name": "units",
        "type": "string",
        "required": false,
        "default_value": "metric",
        "description": "Units of measurement (standard, metric, imperial)"
      }
    ],
    "is_active": true
  },
