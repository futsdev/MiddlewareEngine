    "function_id": "measure-voltage-ch1",
    "name": "Measure Voltage Channel 1",
    "description": "Measures voltage from oscilloscope channel 1",
    "execution_type": "ScpiCommand",
    "execution_config": {
      "scpi_command": "MEAS:VOLT? {channel}",
      "connection_string": "TCPIP::192.168.1.100::5025::SOCKET"
    },
    "parameters": [
      {
        "name": "channel",
        "type": "string",
        "required": true,
        "default_value": "CH1",
        "description": "Channel number (CH1, CH2, CH3, CH4)"
      }
    ],
    "is_active": true
  },
